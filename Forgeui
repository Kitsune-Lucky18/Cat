function ForgeUI.CreateColorPicker(self, config)
	local theme = self.Theme
	local current = config.CurrentColor or Color3.new(1,1,1)
	local Holder = create("Frame", { BackgroundColor3 = theme.Card, Size = UDim2.new(1, 0, 0, 38), ClipsDescendants = true, Parent = self.Page }, { corner(9), strokeUI(theme.Border, 1) })
	create("TextLabel", { Text = config.Name or "Color", Font = FONT_MED, TextSize = 13, TextColor3 = theme.Text, BackgroundTransparency = 1, Size = UDim2.new(1, -60, 0, 38), Position = UDim2.fromOffset(14, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = Holder })
	local Swatch = create("TextButton", { Text = "", BackgroundColor3 = current, Size = UDim2.fromOffset(28, 22), Position = UDim2.new(1, -42, 0, 8), AutoButtonColor = false, Parent = Holder }, { corner(6), strokeUI(theme.Border, 1) })
	local Panel = create("Frame", { BackgroundColor3 = theme.Elevated, Size = UDim2.new(1, -28, 0, 90), Position = UDim2.fromOffset(14, 44), Parent = Holder }, { corner(6) })
	create("UIListLayout", { Padding = UDim.new(0, 6), SortOrder = Enum.SortOrder.LayoutOrder }).Parent = Panel
	create("UIPadding", { PaddingTop = UDim.new(0, 8), PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8) }).Parent = Panel

	local open = false
	local function setOpen(v) open = v; Holder.Size = v and UDim2.new(1, 0, 0, 144) or UDim2.new(1, 0, 0, 38) end
	local r, g, b = current.R * 255, current.G * 255, current.B * 255

	local function channel(label, initial, onChange)
		local Row = create("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20), Parent = Panel })
		create("TextLabel", { Text = label, Font = FONT, TextSize = 11, TextColor3 = theme.SubText, BackgroundTransparency = 1, Size = UDim2.fromOffset(16, 20), Parent = Row })
		local Track = create("Frame", { BackgroundColor3 = theme.Border, Size = UDim2.new(1, -50, 0, 4), Position = UDim2.fromOffset(24, 8), Parent = Row }, { corner(2) })
		local Fill = create("Frame", { BackgroundColor3 = theme.Accent, Size = UDim2.new(initial / 255, 0, 1, 0), Parent = Track }, { corner(2) })
		local dragging = false
		local function update(x)
			local rel = math.clamp((x - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
			Fill.Size = UDim2.new(rel, 0, 1, 0)
			onChange(rel * 255)
		end
		Track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update(i.Position.X) end end)
		UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i.Position.X) end end)
		UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
	end

	local function refresh()
		local color = Color3.fromRGB(r, g, b)
		Swatch.BackgroundColor3 = color
		local ok, err = pcall(config.Callback or function() end, color)
		if not ok then warn("[ForgeUI] ColorPicker error:", err) end
	end
	channel("R", r, function(v) r = v; refresh() end)
	channel("G", g, function(v) g = v; refresh() end)
	channel("B", b, function(v) b = v; refresh() end)
	Swatch.MouseButton1Click:Connect(function() setOpen(not open) end)
	return { Set = function(c) r, g, b = c.R*255, c.G*255, c.B*255; refresh() end }
end

function ForgeUI.CreateKeybind(self, config)
	local theme = self.Theme
	local current = config.CurrentKeybind or "None"
	local Holder = create("Frame", { BackgroundColor3 = theme.Card, Size = UDim2.new(1, 0, 0, 38), Parent = self.Page }, { corner(9), strokeUI(theme.Border, 1) })
	create("TextLabel", { Text = config.Name or "Keybind", Font = FONT_MED, TextSize = 13, TextColor3 = theme.Text, BackgroundTransparency = 1, Size = UDim2.new(1, -96, 1, 0), Position = UDim2.fromOffset(14, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = Holder })
	local BindBtn = create("TextButton", { Text = current, Font = FONT, TextSize = 12, TextColor3 = theme.Text, BackgroundColor3 = theme.Elevated, Size = UDim2.fromOffset(80, 26), Position = UDim2.new(1, -94, 0.5, -13), AutoButtonColor = false, Parent = Holder }, { corner(6) })
	local listening = false
	BindBtn.MouseButton1Click:Connect(function() listening = true; BindBtn.Text = "..." end)
	UserInputService.InputBegan:Connect(function(input)
		if not listening then return end
		if input.UserInputType == Enum.UserInputType.Keyboard then
			current = input.KeyCode.Name
			BindBtn.Text = current
			listening = false
			local ok, err = pcall(config.Callback or function() end, current)
			if not ok then warn("[ForgeUI] Keybind error:", err) end
		end
	end)
	return { Set = function(k) current = k; BindBtn.Text = k end }
end

