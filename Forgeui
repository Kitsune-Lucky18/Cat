-- ============ TAB ============
function ForgeUI.CreateTab(self, name)
	local theme = self.Theme
	local TabBtn = create("TextButton", {
		Text = name, Font = FONT_MED, TextSize = 12.5, TextColor3 = theme.SubText,
		BackgroundColor3 = theme.Elevated, AutoButtonColor = false,
		Size = UDim2.fromOffset(0, 30), AutomaticSize = Enum.AutomaticSize.X, Parent = self._TabBar,
	}, { corner(15) })
	create("UIPadding", { PaddingLeft = UDim.new(0, 16), PaddingRight = UDim.new(0, 16) }).Parent = TabBtn

	local Page = create("ScrollingFrame", {
		Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, BorderSizePixel = 0,
		ScrollBarThickness = 3, ScrollBarImageColor3 = theme.Accent,
		CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false, Parent = self._Body,
	})
	create("UIListLayout", { Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder }).Parent = Page
	create("UIPadding", { PaddingBottom = UDim.new(0, 8) }).Parent = Page

	local Tab = { Page = Page, Theme = theme }
	setmetatable(Tab, ForgeUI)

	local function select()
		for _, t in ipairs(self.Tabs) do
			t.Page.Visible = false
			softTween(t.Button, { BackgroundColor3 = theme.Elevated, TextColor3 = theme.SubText }, 0.15):Play()
		end
		Page.Visible = true
		springTween(TabBtn, { BackgroundColor3 = theme.Accent }, 0.3):Play()
		softTween(TabBtn, { TextColor3 = theme.Light and Color3.new(1,1,1) or theme.Text }, 0.15):Play()
	end

	TabBtn.MouseButton1Click:Connect(select)
	table.insert(self.Tabs, { Button = TabBtn, Page = Page })
	if self._firstTab then self._firstTab = false; select() end
	return Tab
end

