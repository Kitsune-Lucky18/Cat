function ForgeUI.CreateButton(self, config)
	local theme = self.Theme
	local Holder = create("TextButton", { Text = "", BackgroundColor3 = theme.Card, AutoButtonColor = false, Size = UDim2.new(1, 0, 0, 38), Parent = self.Page }, { corner(9), strokeUI(theme.Border, 1) })
	create("TextLabel", { Text = config.Name or "Button", Font = FONT_MED, TextSize = 13, TextColor3 = theme.Text, BackgroundTransparency = 1, Position = UDim2.fromOffset(14, 0), Size = UDim2.new(1, -24, 1, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = Holder })
	hoverColor(Holder, theme.Card, theme.Elevated)
	Holder.MouseButton1Click:Connect(function()
		springTween(Holder, { BackgroundColor3 = theme.Accent }, 0.15):Play()
		task.delay(0.15, function() softTween(Holder, { BackgroundColor3 = theme.Elevated }, 0.2):Play() end)
		local ok, err = pcall(config.Callback or function() end)
		if not ok then warn("[ForgeUI] Button error:", err) end
	end)
	return Holder
end

function ForgeUI.CreateToggle(self, config)
	local theme = self.Theme
	local state = config.CurrentValue or false
	local Holder = create("Frame", { BackgroundColor3 = theme.Card, Size = UDim2.new(1, 0, 0, 38), Parent = self.Page }, { corner(9), strokeUI(theme.Border, 1) })
	create("TextLabel", { Text = config.Name or "Toggle", Font = FONT_MED, TextSize = 13, TextColor3 = theme.Text, BackgroundTransparency = 1, Position = UDim2.fromOffset(14, 0), Size = UDim2.new(1, -58, 1, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = Holder })
	local Switch = create("Frame", { Size = UDim2.fromOffset(36, 19), Position = UDim2.new(1, -48, 0.5, -9.5), BackgroundColor3 = state and theme.Accent or theme.Border, Parent = Holder }, { corner(10) })
	local Knob = create("Frame", { Size = UDim2.fromOffset(15, 15), Position = state and UDim2.new(1, -17, 0.5, -7.5) or UDim2.new(0, 2, 0.5, -7.5), BackgroundColor3 = Color3.new(1,1,1), Parent = Switch }, { corner(8) })
	local Click = create("TextButton", { Text = "", BackgroundTransparency = 1, Size = UDim2.fromScale(1,1), Parent = Holder })
	local function setState(v, fire)
		state = v
		softTween(Switch, { BackgroundColor3 = state and theme.Accent or theme.Border }, 0.15):Play()
		springTween(Knob, { Position = state and UDim2.new(1, -17, 0.5, -7.5) or UDim2.new(0, 2, 0.5, -7.5) }, 0.25):Play()
		if fire then local ok, err = pcall(config.Callback or function() end, state); if not ok then warn("[ForgeUI] Toggle error:", err) end end
	end
	Click.MouseButton1Click:Connect(function() setState(not state, true) end)
	return { Set = function(v) setState(v, true) end, Get = function() return state end }
end

function ForgeUI.CreateSlider(self, config)
	local theme = self.Theme
	local range = config.Range or {0, 100}
	local increment = config.Increment or 1
	local value = config.CurrentValue or range[1]
	local min, max = range[1], range[2]

	local Holder = create("Frame", { BackgroundColor3 = theme.Card, Size = UDim2.new(1, 0, 0, 50), Parent = self.Page }, { corner(9), strokeUI(theme.Border, 1) })
	create("TextLabel", { Text = config.Name or "Slider", Font = FONT_MED, TextSize = 13, TextColor3 = theme.Text, BackgroundTransparency = 1, Size = UDim2.new(1, -70, 0, 24), Position = UDim2.fromOffset(14, 4), TextXAlignment = Enum.TextXAlignment.Left, Parent = Holder })
	local ValueLabel = create("TextLabel", { Text = tostring(value), Font = FONT, TextSize = 11.5, TextColor3 = theme.SubText, BackgroundTransparency = 1, Size = UDim2.fromOffset(50, 24), Position = UDim2.new(1, -62, 0, 4), TextXAlignment = Enum.TextXAlignment.Right, Parent = Holder })
	local Track = create("Frame", { Size = UDim2.new(1, -28, 0, 5), Position = UDim2.fromOffset(14, 34), BackgroundColor3 = theme.Border, Parent = Holder }, { corner(3) })
	local function pct(v) return (v - min) / (max - min) end
	local Fill = create("Frame", { Size = UDim2.new(pct(value), 0, 1, 0), BackgroundColor3 = theme.Accent, Parent = Track }, { corner(3) })
	local Knob = create("Frame", { Size = UDim2.fromOffset(13, 13), Position = UDim2.new(pct(value), -6.5, 0.5, -6.5), BackgroundColor3 = Color3.new(1,1,1), Parent = Track }, { corner(7) })

	local dragging = false
	local function update(x)
		local rel = math.clamp((x - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
		local raw = min + rel * (max - min)
		local stepped = math.clamp(math.floor(raw / increment + 0.5) * increment, min, max)
		if stepped ~= value then
			value = stepped
			ValueLabel.Text = tostring(value)
			Fill.Size = UDim2.new(pct(value), 0, 1, 0)
			Knob.Position = UDim2.new(pct(value), -6.5, 0.5, -6.5)
			local ok, err = pcall(config.Callback or function() end, value)
			if not ok then warn("[ForgeUI] Slider error:", err) end
		end
	end
	Track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true; update(i.Position.X) end end)
	UserInputService.InputChanged:Connect(function(i) if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position.X) end end)
	UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
	return { Set = function(v) update(Track.AbsolutePosition.X + pct(v) * Track.AbsoluteSize.X) end, Get = function() return value end }
end

function ForgeUI.CreateDropdown(self, config)
