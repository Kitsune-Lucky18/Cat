	end
	local current = config.CurrentOption or options[1] or ""

	local Holder = create("Frame", { BackgroundColor3 = theme.Card, Size = UDim2.new(1, 0, 0, 38), ClipsDescendants = true, Parent = self.Page }, { corner(9), strokeUI(theme.Border, 1) })
	create("TextLabel", { Text = config.Name or "Dropdown", Font = FONT_MED, TextSize = 13, TextColor3 = theme.Text, BackgroundTransparency = 1, Size = UDim2.new(0.5, -14, 0, 38), Position = UDim2.fromOffset(14, 0), TextXAlignment = Enum.TextXAlignment.Left, Parent = Holder })
	local SelectedBtn = create("TextButton", { Text = multiSelect and (#config.CurrentOptions or 0) .. " dipilih" or current, Font = FONT, TextSize = 12, TextColor3 = theme.SubText, BackgroundColor3 = theme.Elevated, Size = UDim2.new(0.5, -14, 0, 26), Position = UDim2.new(0.5, 0, 0, 6), AutoButtonColor = false, TextXAlignment = Enum.TextXAlignment.Left, Parent = Holder }, { corner(6) })
	create("UIPadding", { PaddingLeft = UDim.new(0, 10) }).Parent = SelectedBtn
	local ListFrame = create("Frame", { BackgroundColor3 = theme.Elevated, Size = UDim2.new(0.5, -14, 0, #options * 26), Position = UDim2.new(0.5, 0, 0, 38), Parent = Holder }, { corner(6) })
	create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = ListFrame

	local open = false
	local function setOpen(v) open = v; Holder.Size = v and UDim2.new(1, 0, 0, 38 + #options * 26 + 6) or UDim2.new(1, 0, 0, 38) end

	for _, opt in ipairs(options) do
		local OptBtn = create("TextButton", { Text = opt, Font = FONT, TextSize = 12, TextColor3 = theme.Text, BackgroundColor3 = theme.Elevated, BackgroundTransparency = selected[opt] and 0.5 or 1, Size = UDim2.new(1, 0, 0, 26), Parent = ListFrame })
		OptBtn.MouseEnter:Connect(function() if not selected[opt] then softTween(OptBtn, { BackgroundTransparency = 0.7 }, 0.1):Play() end end)
		OptBtn.MouseLeave:Connect(function() if not selected[opt] then softTween(OptBtn, { BackgroundTransparency = 1 }, 0.1):Play() end end)
		OptBtn.MouseButton1Click:Connect(function()
			if multiSelect then
				selected[opt] = not selected[opt]
				OptBtn.BackgroundTransparency = selected[opt] and 0.5 or 1
				local count = 0
				for _ in pairs(selected) do count += 1 end
				SelectedBtn.Text = count .. " dipilih"
				local ok, err = pcall(config.Callback or function() end, selected)
				if not ok then warn("[ForgeUI] Dropdown error:", err) end
			else
				current = opt
				SelectedBtn.Text = current
				setOpen(false)
				local ok, err = pcall(config.Callback or function() end, current)
				if not ok then warn("[ForgeUI] Dropdown error:", err) end
			end
		end)
	end
	SelectedBtn.MouseButton1Click:Connect(function() setOpen(not open) end)
	return { Set = function(v) current = v; SelectedBtn.Text = v end }
end

