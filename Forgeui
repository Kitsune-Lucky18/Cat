-- ============ HELPERS ============
local function create(class, props, children)
	local inst = Instance.new(class)
	for k, v in pairs(props or {}) do inst[k] = v end
	for _, child in ipairs(children or {}) do child.Parent = inst end
	return inst
end

local function corner(r) return create("UICorner", { CornerRadius = UDim.new(0, r or 10) }) end
local function strokeUI(c, t) return create("UIStroke", { Color = c, Thickness = t or 1 }) end

-- Spring-bounce tween: overshoot lalu settle, beda dari ease-out biasa
local function springTween(obj, props, dur)
	return TweenService:Create(obj, TweenInfo.new(dur or 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), props)
end
local function softTween(obj, props, dur)
	return TweenService:Create(obj, TweenInfo.new(dur or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
end

-- Drag standar (snap langsung, tanpa inertia/lerp — beda pendekatan dari referensi sebelumnya)
local function makeDraggable(handle, target)
	local dragging, dragStart, startPos
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = target.Position
			input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
		end
	end)
	handle.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
end

local function hoverColor(button, normal, hover)
	button.MouseEnter:Connect(function() softTween(button, { BackgroundColor3 = hover }):Play() end)
	button.MouseLeave:Connect(function() softTween(button, { BackgroundColor3 = normal }):Play() end)
end

-- ============ LOADING SCREEN ============
function ForgeUI:ShowLoading(config)
	config = config or {}
	local theme = Themes[config.Theme or "Slate"] or Themes.Slate
	local duration = config.Duration or 1.8

	local old = PlayerGui:FindFirstChild("ForgeUI_Loading")
	if old then old:Destroy() end

	local ScreenGui = create("ScreenGui", { Name = "ForgeUI_Loading", ResetOnSpawn = false, Parent = PlayerGui })
	local Backdrop = create("Frame", { Size = UDim2.fromScale(1, 1), BackgroundColor3 = theme.Background, BackgroundTransparency = 1, Parent = ScreenGui })
	softTween(Backdrop, { BackgroundTransparency = 0 }, 0.3):Play()

	-- Indikator loading: 3 dot yang bounce bergantian (beda dari ring spin)
	local DotsWrap = create("Frame", { Size = UDim2.fromOffset(70, 16), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.fromScale(0.5, 0.46), BackgroundTransparency = 1, Parent = Backdrop })
	create("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, HorizontalAlignment = Enum.HorizontalAlignment.Center, Padding = UDim.new(0, 8) }).Parent = DotsWrap

	local dots = {}
	for i = 1, 3 do
		dots[i] = create("Frame", { Size = UDim2.fromOffset(12, 12), BackgroundColor3 = theme.Accent, Parent = DotsWrap }, { corner(6) })
	end

	task.spawn(function()
		local i = 1
		while DotsWrap.Parent do
			for j, dot in ipairs(dots) do
				if j == i then
					springTween(dot, { Size = UDim2.fromOffset(16, 16) }, 0.25):Play()
				else
					softTween(dot, { Size = UDim2.fromOffset(12, 12) }, 0.25):Play()
				end
			end
			i = (i % 3) + 1
			task.wait(0.3)
		end
	end)

	create("TextLabel", {
		Text = config.Title or "Loading", Font = FONT_BOLD, TextSize = 15, TextColor3 = theme.Text,
		AnchorPoint = Vector2.new(0.5, 0), Position = UDim2.new(0.5, 0, 0.46, 28), Size = UDim2.fromOffset(280, 20),
		BackgroundTransparency = 1, Parent = Backdrop,
	})

	task.delay(duration, function()
		local out = softTween(Backdrop, { BackgroundTransparency = 1 }, 0.3)
		out:Play()
		out.Completed:Connect(function()
			ScreenGui:Destroy()
			if config.OnComplete then config.OnComplete() end
		end)
	end)
end

