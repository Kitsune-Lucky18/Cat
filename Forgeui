	local gui = create("ScreenGui", { Name = "ForgeUI_Notify", ResetOnSpawn = false, Parent = PlayerGui })
	NotifyHolder = create("Frame", { Size = UDim2.fromOffset(290, 440), Position = UDim2.new(1, -306, 1, -20), AnchorPoint = Vector2.new(0, 1), BackgroundTransparency = 1, Parent = gui })
	create("UIListLayout", { VerticalAlignment = Enum.VerticalAlignment.Bottom, Padding = UDim.new(0, 8) }).Parent = NotifyHolder
	return NotifyHolder
end

function ForgeUI:Notify(config)
	config = config or {}
	local theme = ActiveTheme
	local colorMap = { Good = theme.Good, Bad = theme.Bad, Warn = theme.Warn }
	local barColor = colorMap[config.Type] or theme.Accent
	local holder = ensureNotifyHolder()

	local card = create("Frame", { Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = theme.Card, ClipsDescendants = true, Parent = holder }, { corner(10), strokeUI(theme.Border, 1) })
	create("Frame", { Size = UDim2.new(0, 3, 1, -16), Position = UDim2.fromOffset(0, 8), BackgroundColor3 = barColor, Parent = card }, { corner(2) })
	create("TextLabel", { Text = config.Title or "Notification", Font = FONT_BOLD, TextSize = 12.5, TextColor3 = theme.Text, BackgroundTransparency = 1, Position = UDim2.fromOffset(15, 9), Size = UDim2.new(1, -26, 0, 16), TextXAlignment = Enum.TextXAlignment.Left, Parent = card })
	if config.Content then
		create("TextLabel", { Text = config.Content, Font = FONT, TextSize = 11, TextColor3 = theme.SubText, BackgroundTransparency = 1, Position = UDim2.fromOffset(15, 26), Size = UDim2.new(1, -26, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left, Parent = card })
	end
	create("UIPadding", { PaddingBottom = UDim.new(0, 10) }).Parent = card

	card.Position = UDim2.new(1, 30, 0, 0)
	springTween(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.4):Play()
	task.delay(config.Duration or 4, function()
		local out = softTween(card, { Position = UDim2.new(1, 30, 0, 0) }, 0.25)
		out:Play()
		out.Completed:Connect(function() card:Destroy() end)
	end)
end

