    -- Dynamic Text Color for Cyberpunk Theme Target Integration
    local verifyTextColor = (selectedTheme == "Cyberpunk") and Color3.fromRGB(15, 15, 10) or Color3.fromRGB(255, 255, 255)

    local verifyBtn = CreateElement("TextButton", {
        Text = "Verify Token", Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = verifyTextColor,
        Position = UDim2.new(0.52, 0, 0, 0), Size = UDim2.new(0.48, 0, 1, 0), BackgroundColor3 = currentTheme.AccentPrimary, AutoButtonColor = false, Parent = btnGrid
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 10), Parent = verifyBtn})
    ApplyButtonEffects(verifyBtn, currentTheme.AccentPrimary, currentTheme.AccentSecondary)

    -- Functional Bindings
    getKeyBtn.MouseButton1Click:Connect(function()
        if setclipboard and self.GetKeyLink ~= "" then
            setclipboard(self.GetKeyLink)
            self:Notify({Title = "Kitsune Security", Content = "URL Key bypass disalin ke clipboard!", Duration = 3})
        else
            self:Notify({Title = "Kitsune Security", Content = "Gagal menyalin (Fitur clipboard tidak didukung).", Duration = 3})
        end
    end)

    verifyBtn.MouseButton1Click:Connect(function()
        if textBox.Text == self.TargetKey then
            self:Notify({Title = "Sistem Terverifikasi", Content = "Token valid! Mengunduh dependensi script...", Duration = 3})
            
            if self.ScriptToRun ~= "" then
                task.spawn(function()
                    pcall(function()
                        loadstring(game:HttpGet(self.ScriptToRun))()
                    end)
                end)
            end
            
            task.delay(1, function() self:DestroyUI() end)
        else
            self:Notify({Title = "Validasi Gagal", Content = "Token salah! Ambil token baru via panel sebelah kiri.", Duration = 4})
        end
    end)

    -- Soft Material Easing Entrance
    TweenService:Create(self.MainFrame, TweenInfo.new(0.45, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 410, 0, 215),
        BackgroundTransparency = 0
    }):Play()
    TweenService:Create(mainStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Transparency = 0}):Play()

    return self
end

-- Premium Notification Builder
function KitsuneKeyUI:Notify(cfg)
    local currentTheme = self.Theme
    local card = CreateElement("Frame", {
        Size = UDim2.new(1, 0, 0, 58), BackgroundColor3 = currentTheme.CardBackground, BackgroundTransparency = 1, Parent = self.NotificationContainer
    }, {
        CreateElement("UICorner", {CornerRadius = UDim.new(0, 10)}),
        CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border}),
        CreateElement("Frame", {Size = UDim2.new(0, 4, 1, 0), BackgroundColor3 = currentTheme.AccentPrimary})
    })

    CreateElement("TextLabel", {
        Text = cfg.Title or "Notification", Font = Enum.Font.GothamBold, TextSize = 12.5, TextColor3 = currentTheme.TextPrimary,
        Position = UDim2.new(0, 16, 0, 8), Size = UDim2.new(1, -24, 0, 16), BackgroundTransparency = 1, Parent = card
    })
    CreateElement("TextLabel", {
        Text = cfg.Content or "", Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = currentTheme.TextSecondary,
        Position = UDim2.new(0, 16, 0, 24), Size = UDim2.new(1, -24, 0, 26), TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top, BackgroundTransparency = 1, Parent = card
    })

    TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
    task.delay(cfg.Duration or 4, function()
        local close = TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, Size = UDim2.new(1,0,0,0)})
        close:Play() close.Completed:Connect(function() card:Destroy() end)
    end)
end

function KitsuneKeyUI:DestroyUI()
    if self.MainFrame then
        local closeTween = TweenService:Create(self.MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 410, 0, 0),
            BackgroundTransparency = 1
        })
        closeTween:Play()
        closeTween.Completed:Connect(function()
            self.ScreenGui:Destroy()
        end)
    end
end

return KitsuneKeyUI
