-- Premium Fluid Toast Notification
function KitsuneKeyUI:Notify(cfg)
    local currentTheme = self.Theme
    local card = CreateElement("Frame", {
        Size = UDim2.new(1, 0, 0, 58), BackgroundColor3 = currentTheme.CardBackground, BackgroundTransparency = 1, Parent = self.NotificationContainer
    }, {
        CreateElement("UICorner", {CornerRadius = UDim.new(0, 10)}),
        CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border}),
        CreateElement("Frame", {Size = UDim2.new(0, 4, 1, 0), BackgroundColor3 = currentTheme.AccentPrimary})
    })

    CreateElement("TextLabel", {
        Text = cfg.Title or "System Notice", Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = currentTheme.TextPrimary,
        Position = UDim2.new(0, 16, 0, 8), Size = UDim2.new(1, -24, 0, 16), BackgroundTransparency = 1, Parent = card
    })
    CreateElement("TextLabel", {
        Text = cfg.Content or "", Font = Enum.Font.Gotham, TextSize = 10.5, TextColor3 = currentTheme.TextSecondary,
        Position = UDim2.new(0, 16, 0, 24), Size = UDim2.new(1, -24, 0, 26), TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top, BackgroundTransparency = 1, Parent = card
    })

    TweenService:Create(card, TweenInfo.new(0.4, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
    
    task.delay(cfg.Duration or 4, function()
        local close = TweenService:Create(card, TweenInfo.new(0.4, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {BackgroundTransparency = 1, Size = UDim2.new(1,0,0,0)})
        close:Play() 
        close.Completed:Connect(function() card:Destroy() end)
    end)
end

-- Premium Fade Exit
function KitsuneKeyUI:DestroyUI()
    if self.MainFrame then
        local closeTween = TweenService:Create(self.MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            GroupTransparency = 1
        })
        closeTween:Play()
        closeTween.Completed:Connect(function()
            self.ScreenGui:Destroy()
        end)
    end
end

return KitsuneKeyUI
