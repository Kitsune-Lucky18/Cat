local function CreateElement(className, properties, children)
    local element = Instance.new(className)
    for key, value in pairs(properties) do
        element[key] = value
    end
    if children then
        for _, child in pairs(children) do
            child.Parent = element
        end
    end
    return element
end

-- Ultra Smooth Inertia Draggable (Lerp Mechanics)
local function MakeSmoothDraggable(dragFrame, parentFrame)
    local dragging, dragInput, dragStart, startPos
    local targetPos = parentFrame.Position

    dragFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = parentFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    dragFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Render Loop for Inertia Effect
    game:GetService("RunService").RenderStepped:Connect(function()
        parentFrame.Position = parentFrame.Position:Lerp(targetPos, 0.22) -- Kecepatan respons seret (0.22 sangat smooth)
    end)
end

-- Micro-Animate Button Elastic Effects
local function ApplyButtonEffects(button, normalColor, hoverColor)
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
            BackgroundColor3 = hoverColor
        }):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
            BackgroundColor3 = normalColor
        }):Play()
    end)
end

