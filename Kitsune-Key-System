-- Helper Elements Builder
local function CreateElement(className, properties, children)
    local element = Instance.new(className)
    for key, value in pairs(properties) do
        element[key] = value
    end
    if children then
        for _, child in pairs(children) do
            child.Parent = element
        end
    end
    return element
end

-- Smooth Draggable System
local function MakeDraggable(dragFrame, parentFrame)
    local dragging, dragInput, dragStart, startPos
    dragFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = parentFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    dragFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            TweenService:Create(parentFrame, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }):Play()
        end
    end)
end

-- Premium Button Hover Effect
local function ApplyButtonEffects(button, normalColor, hoverColor)
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = hoverColor,
            Size = UDim2.new(button.Size.X.Scale, button.Size.X.Offset, button.Size.Y.Scale, button.Size.Y.Offset + 2)
        }):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = normalColor,
            Size = UDim2.new(button.Size.X.Scale, button.Size.X.Offset, button.Size.Y.Scale, button.Size.Y.Offset - 2)
        }):Play()
    end)
end

-- Main Window Creation
function KitsuneKeyUI:CreateWindow(config)
    local self = setmetatable({}, KitsuneKeyUI)
    
    -- Ambil tema yang dipilih atau gunakan default "Dark Kitsune"
    local selectedTheme = config.Theme or "Dark Kitsune"
    self.Theme = Themes[selectedTheme] or Themes["Dark Kitsune"]
    local currentTheme = self.Theme

    self.Title = config.Title or "Kitsune Key System"
    self.TargetKey = config.Key or "Kitsune666"
    self.GetKeyLink = config.GetKeyLink or ""
    self.ScriptToRun = config.ScriptOnSuccess or ""
    
    -- Main ScreenGui
    self.ScreenGui = CreateElement("ScreenGui", {
        Name = UI_NAME,
        ResetOnSpawn = false,
        Parent = PlayerGui
    })

    -- Notification Setup
    self.NotificationContainer = CreateElement("Frame", {
        Size = UDim2.new(0, 310, 1, -40),
        Position = UDim2.new(1, -330, 0, 20),
        BackgroundTransparency = 1,
        Parent = self.ScreenGui
    }, {
        CreateElement("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), VerticalAlignment = Enum.VerticalAlignment.Bottom})
    })

    -- Modern Key Window Center Frame
    self.MainFrame = CreateElement("Frame", {
        Size = UDim2.new(0, 420, 0, 0), -- Start di 0 untuk animasi open
        Position = UDim2.new(0.5, -210, 0.5, -115),
        BackgroundColor3 = currentTheme.Background,
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = self.ScreenGui
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 12), Parent = self.MainFrame})
    local mainStroke = CreateElement("UIStroke", {Thickness = 1.2, Color = currentTheme.Border, Transparency = 1, Parent = self.MainFrame})

    -- Elegant Top Gradient Glow
    local topGlow = CreateElement("Frame", {Size = UDim2.new(1, 0, 0, 3), BackgroundColor3 = Color3.new(1,1,1), Parent = self.MainFrame}, {
        CreateElement("UIGradient", {Color = ColorSequence.new(currentTheme.AccentPrimary, currentTheme.AccentSecondary)})
    })

    -- Header / Drag Bar
    local header = CreateElement("Frame", {Size = UDim2.new(1, 0, 0, 45), BackgroundTransparency = 1, Parent = self.MainFrame})
    MakeDraggable(header, self.MainFrame)

    CreateElement("TextLabel", {
        Text = self.Title, Font = Enum.Font.GothamBold, TextSize = 15, TextColor3 = currentTheme.TextPrimary,
        Position = UDim2.new(0, 18, 0, 0), Size = UDim2.new(0.7, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1, Parent = header
    })

    -- Close Button
    local closeBtn = CreateElement("TextButton", {
        Text = "×", Font = Enum.Font.GothamMedium, TextSize = 22, TextColor3 = currentTheme.TextSecondary,
        Position = UDim2.new(1, -40, 0.5, -14), Size = UDim2.new(0, 28, 0, 28), BackgroundColor3 = currentTheme.CardBackground, Parent = header
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 6), Parent = closeBtn})
    closeBtn.MouseButton1Click:Connect(function() self:DestroyUI() end)

    -- Container Body
    local body = CreateElement("Frame", {
        Position = UDim2.new(0, 20, 0, 55), Size = UDim2.new(1, -40, 1, -75), BackgroundTransparency = 1, Parent = self.MainFrame
    })

    CreateElement("TextLabel", {
        Text = "Silahkan masukkan access key kamu untuk verifikasi sistem keamanan script.", 
        Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = currentTheme.TextSecondary, TextWrapped = true,
        Size = UDim2.new(1, 0, 0, 30), TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top,
        BackgroundTransparency = 1, Parent = body
    })

    -- Modern Input TextBox Card
    local inputCard = CreateElement("Frame", {
        Position = UDim2.new(0, 0, 0, 40), Size = UDim2.new(1, 0, 0, 42),
        BackgroundColor3 = currentTheme.CardBackground, Parent = body
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 8), Parent = inputCard})
    CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = inputCard})

    local textBox = CreateElement("TextBox", {
        Size = UDim2.new(1, -24, 1, 0), Position = UDim2.new(0, 12, 0, 0), BackgroundTransparency = 1,
        Text = "", PlaceholderText = "Masukkan Security Key Disini...", Font = Enum.Font.Gotham, TextSize = 13,
        TextColor3 = currentTheme.TextPrimary, PlaceholderColor3 = selectedTheme == "White Kitsune" and Color3.fromRGB(160, 160, 170) or Color3.fromRGB(110, 95, 95), Parent = inputCard
    })

    -- Action Grid Buttons
    local btnGrid = CreateElement("Frame", {
        Position = UDim2.new(0, 0, 0, 98), Size = UDim2.new(1, 0, 0, 38), BackgroundTransparency = 1, Parent = body
    })

    local getKeyBtn = CreateElement("TextButton", {
        Text = "Get Key", Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = currentTheme.TextPrimary,
        Size = UDim2.new(0.48, 0, 1, 0), BackgroundColor3 = currentTheme.CardBackground, Parent = btnGrid
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 8), Parent = getKeyBtn})
    CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = getKeyBtn})
    ApplyButtonEffects(getKeyBtn, currentTheme.CardBackground, currentTheme.Border)

    local verifyBtn = CreateElement("TextButton", {
        Text = "Verify Key", Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = Color3.fromRGB(255, 255, 255), -- Tetap putih agar kontras di accent merah
        Position = UDim2.new(0.52, 0, 0, 0), Size = UDim2.new(0.48, 0, 1, 0), BackgroundColor3 = currentTheme.AccentPrimary, Parent = btnGrid
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 8), Parent = verifyBtn})
    ApplyButtonEffects(verifyBtn, currentTheme.AccentPrimary, currentTheme.AccentSecondary)

    -- Logic Connection
    getKeyBtn.MouseButton1Click:Connect(function()
        if setclipboard and self.GetKeyLink ~= "" then
            setclipboard(self.GetKeyLink)
            self:Notify({Title = "Kitsune System", Content = "Link Key berhasil disalin ke clipboard!", Duration = 3})
        else
            self:Notify({Title = "Kitsune System", Content = "Gagal menyalin link (Executor tidak mendukung clipboard).", Duration = 3})
        end
    end)

    verifyBtn.MouseButton1Click:Connect(function()
        if textBox.Text == self.TargetKey then
            self:Notify({Title = "Akses Diterima", Content = "Key Benar! Menjalankan script utama...", Duration = 3})
            
            if self.ScriptToRun ~= "" then
                task.spawn(function()
                    pcall(function()
                        loadstring(game:HttpGet(self.ScriptToRun))()
                    end)
                end)
            end
            
            task.delay(1, function() self:DestroyUI() end)
        else
            self:Notify({Title = "Akses Ditolak", Content = "Key salah atau kadaluwarsa! Silahkan coba lagi.", Duration = 4})
        end
    end)

    -- Entrance Scale Animation
    TweenService:Create(self.MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 420, 0, 210),
        BackgroundTransparency = 0
    }):Play()
    TweenService:Create(mainStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Transparency = 0}):Play()

    return self
end

-- Premium Notification Builder
function KitsuneKeyUI:Notify(cfg)
    local currentTheme = self.Theme
    local card = CreateElement("Frame", {
        Size = UDim2.new(1, 0, 0, 55), BackgroundColor3 = currentTheme.CardBackground, BackgroundTransparency = 1, Parent = self.NotificationContainer
    }, {
        CreateElement("UICorner", {CornerRadius = UDim.new(0, 8)}),
        CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border}),
        CreateElement("Frame", {Size = UDim2.new(0, 4, 1, 0), BackgroundColor3 = currentTheme.AccentPrimary})
    })

    CreateElement("TextLabel", {
        Text = cfg.Title or "Notification", Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = currentTheme.TextPrimary,
        Position = UDim2.new(0, 14, 0, 6), Size = UDim2.new(1, -20, 0, 16), BackgroundTransparency = 1, Parent = card
    })
    CreateElement("TextLabel", {
        Text = cfg.Content or "", Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = currentTheme.TextSecondary,
        Position = UDim2.new(0, 14, 0, 22), Size = UDim2.new(1, -20, 0, 26), TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top, BackgroundTransparency = 1, Parent = card
    })

    TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
    task.delay(cfg.Duration or 4, function()
        local close = TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1, Size = UDim2.new(1,0,0,0)})
        close:Play() close.Completed:Connect(function() card:Destroy() end)
    end)
end

-- Safe Cleanup
function KitsuneKeyUI:DestroyUI()
    if self.MainFrame then
        local closeTween = TweenService:Create(self.MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 420, 0, 0),
            BackgroundTransparency = 1
        })
        closeTween:Play()
        closeTween.Completed:Connect(function()
            self.ScreenGui:Destroy()
        end)
    end
end

return KitsuneKeyUI
