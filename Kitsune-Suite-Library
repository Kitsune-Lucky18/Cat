    local elementLayout = Instance.new("UIListLayout")
    elementLayout.SortOrder = Enum.SortOrder.LayoutOrder
    elementLayout.Padding = UDim.new(0, 8)
    elementLayout.Parent = tabScroll

    local elementPadding = Instance.new("UIPadding")
    elementPadding.PaddingTop = UDim.new(0, 16)
    elementPadding.PaddingLeft = UDim.new(0, 16)
    elementPadding.PaddingRight = UDim.new(0, 16)
    elementPadding.Parent = tabScroll
    
    elementLayout.Changed:Connect(function()
        tabScroll.CanvasSize = UDim2.new(0, 0, 0, elementLayout.AbsoluteContentSize.Y + 32)
    end)

    local function Activate()
        if self.ActiveTab then
            TweenService:Create(self.ActiveTab.Button, TweenInfo.new(0.2), {BackgroundTransparency = 0.2, TextColor3 = currentTheme.TextSecondary}):Play()
            TweenService:Create(self.ActiveTab.Stroke, TweenInfo.new(0.2), {Color = currentTheme.Border}):Play()
            TweenService:Create(self.ActiveTab.Strip, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            self.ActiveTab.Scroll.Visible = false
        end
        TweenService:Create(tabButton, TweenInfo.new(0.2), {BackgroundTransparency = 0, TextColor3 = currentTheme.TextPrimary}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2), {Color = currentTheme.AccentPrimary}):Play()
        TweenService:Create(accentStrip, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
        tabScroll.Visible = true
        self.ActiveTab = {Button = tabButton, Stroke = btnStroke, Strip = accentStrip, Scroll = tabScroll}
    end

    tabButton.MouseButton1Click:Connect(Activate)
    
    local actualButtons = 0
    for _, child in pairs(self.Sidebar:GetChildren()) do
        if child:IsA("TextButton") then actualButtons = actualButtons + 1 end
    end
    if actualButtons == 1 then Activate() end

