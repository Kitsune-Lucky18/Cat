        local label = Instance.new("TextLabel") label.Text = text label.Font = Enum.Font.GothamMedium label.TextSize = 12 label.TextColor3 = currentTheme.TextPrimary label.Position = UDim2.new(0, 14, 0, 0) label.Size = UDim2.new(0, 300, 1, 0) label.TextXAlignment = Enum.TextXAlignment.Left label.BackgroundTransparency = 1 label.Parent = card

        local switch = Instance.new("TextButton") switch.Text = "" switch.Size = UDim2.new(0, 36, 0, 20) switch.Position = UDim2.new(1, -50, 0.5, -10) switch.BackgroundColor3 = enabled and currentTheme.AccentPrimary or currentTheme.Background switch.AutoButtonColor = false switch.Parent = card
        local swCorner = Instance.new("UICorner") swCorner.CornerRadius = UDim.new(1, 0) swCorner.Parent = switch
        local circle = Instance.new("Frame") circle.Size = UDim2.new(0, 14, 0, 14) circle.Position = enabled and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7) circle.BackgroundColor3 = currentTheme.TextPrimary circle.Parent = switch
        local circCorner = Instance.new("UICorner") circCorner.CornerRadius = UDim.new(1, 0) circCorner.Parent = circle

        switch.MouseButton1Click:Connect(function()
            enabled = not enabled
            TweenService:Create(switch, TweenInfo.new(0.15), {BackgroundColor3 = enabled and currentTheme.AccentPrimary or currentTheme.Background}):Play()
            TweenService:Create(circle, TweenInfo.new(0.15), {Position = enabled and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)}):Play()
            pcall(callback, enabled)
        end)
    end

    function tabSelf:CreateSlider(text, min, max, default, callback)
        local value = default or min
        local card = Instance.new("Frame") card.Size = UDim2.new(1, 0, 0, 52) card.BackgroundColor3 = currentTheme.CardBackground card.Parent = tabScroll
        local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, 6) c.Parent = card
        local stroke = Instance.new("UIStroke") stroke.Thickness = 1 stroke.Color = currentTheme.Border stroke.Parent = card
        
        local title = Instance.new("TextLabel") title.Text = text title.Font = Enum.Font.GothamMedium title.TextSize = 12 title.TextColor3 = currentTheme.TextPrimary title.Position = UDim2.new(0, 14, 0, 8) title.Size = UDim2.new(0.6, 0, 0, 16) title.TextXAlignment = Enum.TextXAlignment.Left title.BackgroundTransparency = 1 title.Parent = card
        local valueLabel = Instance.new("TextLabel") valueLabel.Text = tostring(value) valueLabel.Font = Enum.Font.GothamBold valueLabel.TextSize = 12 valueLabel.TextColor3 = currentTheme.AccentPrimary valueLabel.Position = UDim2.new(1, -64, 0, 8) valueLabel.Size = UDim2.new(0, 50, 0, 16) valueLabel.TextXAlignment = Enum.TextXAlignment.Right valueLabel.BackgroundTransparency = 1 valueLabel.Parent = card

        local slideTrack = Instance.new("TextButton") slideTrack.Text = "" slideTrack.Size = UDim2.new(1, -28, 0, 5) slideTrack.Position = UDim2.new(0, 14, 1, -14) slideTrack.BackgroundColor3 = currentTheme.Background slideTrack.AutoButtonColor = false slideTrack.Parent = card
        local trkCorner = Instance.new("UICorner") trkCorner.CornerRadius = UDim.new(1, 0) trkCorner.Parent = slideTrack
        local slideFill = Instance.new("Frame") slideFill.Size = UDim2.new((value - min)/(max - min), 0, 1, 0) slideFill.BackgroundColor3 = currentTheme.AccentPrimary slideFill.Parent = slideTrack
        local fillCorner = Instance.new("UICorner") fillCorner.CornerRadius = UDim.new(1, 0) fillCorner.Parent = slideFill

        local function updateSlider(input)
            local scale = math.clamp((input.Position.X - slideTrack.AbsolutePosition.X) / slideTrack.AbsoluteSize.X, 0, 1)
            value = math.floor(min + (max - min) * scale)
            valueLabel.Text = tostring(value) slideFill.Size = UDim2.new(scale, 0, 1, 0) pcall(callback, value)
        end
        local sliding = false
        slideTrack.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true updateSlider(input) end end)
        UserInputService.InputChanged:Connect(function(input) if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then updateSlider(input) end end)
        UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end end)
    end

    function tabSelf:CreateDropdown(text, list, isMultiSelect, callback)
        local expanded = false
        local selections = {}
        local card = Instance.new("Frame") card.Size = UDim2.new(1, 0, 0, 42) card.BackgroundColor3 = currentTheme.CardBackground card.ClipsDescendants = true card.Parent = tabScroll
        local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, 6) c.Parent = card
        local stroke = Instance.new("UIStroke") stroke.Thickness = 1 stroke.Color = currentTheme.Border stroke.Parent = card

        local btn = Instance.new("TextButton") btn.Text = text .. "    ▼" btn.Font = Enum.Font.GothamMedium btn.TextSize = 12 btn.TextColor3 = currentTheme.TextPrimary btn.Size = UDim2.new(1, 0, 0, 42) btn.BackgroundTransparency = 1 btn.AutoButtonColor = false btn.TextXAlignment = Enum.TextXAlignment.Left btn.Parent = card
        local btnPad = Instance.new("UIPadding") btnPad.PaddingLeft = UDim.new(0, 14) btnPad.Parent = btn

        local itemHolder = Instance.new("Frame") itemHolder.Position = UDim2.new(0, 0, 0, 42) itemHolder.Size = UDim2.new(1, 0, 0, 0) itemHolder.BackgroundTransparency = 1 itemHolder.Visible = false itemHolder.Parent = card
        local itemLayout = Instance.new("UIListLayout") itemLayout.SortOrder = Enum.SortOrder.LayoutOrder itemLayout.Parent = itemHolder

        for _, option in pairs(list) do
            local item = Instance.new("TextButton") item.Text = option item.Font = Enum.Font.Gotham item.TextSize = 11.5 item.TextColor3 = currentTheme.TextSecondary item.Size = UDim2.new(1, 0, 0, 30) item.BackgroundTransparency = 1 item.TextXAlignment = Enum.TextXAlignment.Left item.Parent = itemHolder
            local itemPad = Instance.new("UIPadding") itemPad.PaddingLeft = UDim.new(0, 14) itemPad.Parent = item
            
            item.MouseButton1Click:Connect(function()
                if not isMultiSelect then
                    btn.Text = text .. " : " .. option .. "    ▼"
                    expanded = false itemHolder.Visible = false
                    TweenService:Create(card, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 42)}):Play()
                    pcall(callback, option)
                else
                    if table.find(selections, option) then
                        table.remove(selections, table.find(selections, option))
                        item.TextColor3 = currentTheme.TextSecondary
                    else
                        table.insert(selections, option)
                        item.TextColor3 = currentTheme.AccentPrimary
                    end
                    btn.Text = text .. " : [" .. table.concat(selections, ", ") .. "]    ▼"
                    pcall(callback, selections)
                end
            end)
        end

        btn.MouseButton1Click:Connect(function()
            expanded = not expanded
            if expanded then
                itemHolder.Visible = true
                TweenService:Create(card, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 42 + itemLayout.AbsoluteContentSize.Y)}):Play()
            else
                itemHolder.Visible = false
                TweenService:Create(card, TweenInfo.new(0.18), {Size = UDim2.new(1, 0, 0, 42)}):Play()
            end
        end)
    end

