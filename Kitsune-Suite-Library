    function tabSelf:CreateKeybind(text, defaultKey, callback)
        local boundKey = defaultKey
        local awaitingBind = false

        local card = Instance.new("Frame") card.Size = UDim2.new(1, 0, 0, 44) card.BackgroundColor3 = currentTheme.CardBackground card.Parent = tabScroll
        local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, 6) c.Parent = card
        local stroke = Instance.new("UIStroke") stroke.Thickness = 1 stroke.Color = currentTheme.Border stroke.Parent = card

        local label = Instance.new("TextLabel") label.Text = text label.Font = Enum.Font.GothamMedium label.TextSize = 12 label.TextColor3 = currentTheme.TextPrimary label.Position = UDim2.new(0, 14, 0, 0) label.Size = UDim2.new(0.6, 0, 1, 0) label.TextXAlignment = Enum.TextXAlignment.Left label.BackgroundTransparency = 1 label.Parent = card

        local bButton = Instance.new("TextButton") bButton.Text = boundKey.Name bButton.Font = Enum.Font.GothamBold bButton.TextSize = 11 bButton.TextColor3 = currentTheme.AccentPrimary bButton.Size = UDim2.new(0, 80, 0, 26) bButton.Position = UDim2.new(1, -94, 0.5, -13) bButton.BackgroundColor3 = currentTheme.Background bButton.AutoButtonColor = false bButton.Parent = card
        local btnCorner = Instance.new("UICorner") btnCorner.CornerRadius = UDim.new(0, 4) btnCorner.Parent = bButton
        local btnStroke = Instance.new("UIStroke") btnStroke.Thickness = 1 btnStroke.Color = currentTheme.Border btnStroke.Parent = bButton

        bButton.MouseButton1Click:Connect(function()
            awaitingBind = true
            bButton.Text = "..."
        end)

        UserInputService.InputBegan:Connect(function(input, processed)
            if awaitingBind and not processed then
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    boundKey = input.KeyCode
                    awaitingBind = false
                    bButton.Text = boundKey.Name
                    pcall(callback, boundKey)
                end
            elseif not awaitingBind and not processed and input.KeyCode == boundKey then
                pcall(callback, boundKey)
            end
        end)
    end

