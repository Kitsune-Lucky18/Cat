    ["Dark Kitsune"]    = {Background = Color3.fromRGB(16, 16, 18),   CardBackground = Color3.fromRGB(24, 24, 28),  TabActive = Color3.fromRGB(34, 34, 40),   AccentPrimary = Color3.fromRGB(235, 35, 50),   AccentSecondary = Color3.fromRGB(150, 15, 25),  TextPrimary = Color3.fromRGB(255, 255, 255), TextSecondary = Color3.fromRGB(200, 200, 205), Border = Color3.fromRGB(42, 42, 50)},
    ["Midnight Token"]  = {Background = Color3.fromRGB(8, 9, 13),    CardBackground = Color3.fromRGB(16, 18, 26),  TabActive = Color3.fromRGB(26, 30, 44),   AccentPrimary = Color3.fromRGB(90, 105, 245),  AccentSecondary = Color3.fromRGB(60, 70, 185),  TextPrimary = Color3.fromRGB(255, 255, 255), TextSecondary = Color3.fromRGB(195, 200, 215), Border = Color3.fromRGB(30, 34, 50)}
