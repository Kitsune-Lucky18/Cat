local function CreateElement(className, properties, children)
    local element = Instance.new(className)
    for key, value in pairs(properties) do element[key] = value end
    if children then
        for _, child in pairs(children) do child.Parent = element end
    end
    return element
end

local function MakeSmoothDraggable(dragFrame, parentFrame)
    local dragging, dragInput, dragStart, startPos
    local targetPos = parentFrame.Position

    dragFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = parentFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)

    dragFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    RunService.RenderStepped:Connect(function()
        parentFrame.Position = parentFrame.Position:Lerp(targetPos, 0.22)
    end)
end

function KitsuneLib:CreateWindow(config)
    local self = setmetatable({}, KitsuneLib)
    
    local selectedTheme = config.Theme or "Dark Kitsune"
    self.Theme = Themes[selectedTheme] or Themes["Dark Kitsune"]
    local currentTheme = self.Theme
    
    self.Tabs = {}
    self.ActiveTab = nil
    self.IsMinimized = false
    self.IsVisible = true
    self.ToggleKey = config.ToggleKey or Enum.KeyCode.RightControl

    -- Main Screen Gui
    self.ScreenGui = CreateElement("ScreenGui", {Name = UI_NAME, ResetOnSpawn = false, Parent = PlayerGui})
    
    -- Drop Shadow Effect
    self.ShadowFrame = CreateElement("ImageLabel", {
        Size = UDim2.new(0, 580 + 34, 0, 380 + 34),
        Position = UDim2.new(0.5, -307, 0.5, -207),
        BackgroundTransparency = 1,
        Image = "rbxassetid://6015897843",
        ImageColor3 = currentTheme.AccentPrimary,
        ImageTransparency = 0.6,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        Parent = self.ScreenGui
    })

    -- MainWindow Board
    self.MainFrame = CreateElement("Frame", {
        Size = UDim2.new(1, -34, 1, -34),
        Position = UDim2.new(0, 17, 0, 17),
        BackgroundColor3 = currentTheme.Background,
        ClipsDescendants = true,
        Parent = self.ShadowFrame
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 10), Parent = self.MainFrame})
    CreateElement("UIStroke", {Thickness = 1.2, Color = currentTheme.Border, Parent = self.MainFrame})

    -- Drag Strip Header Area
    local dragHeader = CreateElement("Frame", {
        Size = UDim2.new(1, 0, 0, 45),
        BackgroundColor3 = currentTheme.CardBackground,
        Parent = self.MainFrame
    })
    CreateElement("Frame", {Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0,0,1,-1), BackgroundColor3 = currentTheme.Border, BorderSizePixel = 0, Parent = dragHeader})
    MakeSmoothDraggable(dragHeader, self.ShadowFrame)

    -- Brand Title Label
    CreateElement("TextLabel", {
        Text = config.Title or "Kitsune Hub v6", Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = currentTheme.TextPrimary,
        Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(0.5, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Parent = dragHeader
    })

    -- Top Window Controllers (Minimize / Close)
    local controlsHolder = CreateElement("Frame", {
        Size = UDim2.new(0, 70, 1, 0), Position = UDim2.new(1, -80, 0, 0), BackgroundTransparency = 1, Parent = dragHeader
    })
    CreateElement("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal, HorizontalAlignment = Enum.HorizontalAlignment.Right, VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 8), Parent = controlsHolder
    })

    local minimizeBtn = CreateElement("TextButton", {
        Text = "—", Font = Enum.Font.GothamBold, TextSize = 10, TextColor3 = currentTheme.TextSecondary,
        Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = currentTheme.Background, AutoButtonColor = false, Parent = controlsHolder
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 5), Parent = minimizeBtn})
    CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = minimizeBtn})

    local closeBtn = CreateElement("TextButton", {
        Text = "×", Font = Enum.Font.GothamMedium, TextSize = 16, TextColor3 = currentTheme.TextSecondary,
        Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = currentTheme.Background, AutoButtonColor = false, Parent = controlsHolder
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 5), Parent = closeBtn})
    CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = closeBtn})

    -- Minimize and Close Actions
    minimizeBtn.MouseButton1Click:Connect(function()
        self.IsMinimized = not self.IsMinimized
        local targetSize = self.IsMinimized and UDim2.new(0, 580 + 34, 0, 45 + 34) or UDim2.new(0, 580 + 34, 0, 380 + 34)
        TweenService:Create(self.ShadowFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = targetSize}):Play()
    end)

    closeBtn.MouseButton1Click:Connect(function()
        local closeTween = TweenService:Create(self.MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(1-34, 0, 0, 0)})
        closeTween:Play()
        closeTween.Completed:Connect(function() self.ScreenGui:Destroy() end)
    end)

    -- Universal Toggle Key Trigger
    UserInputService.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == self.ToggleKey then
            self.IsVisible = not self.IsVisible
            self.ShadowFrame.Visible = self.IsVisible
        end
    end)

    -- Sidebar Holder Frame
    self.Sidebar = CreateElement("Frame", {
        Position = UDim2.new(0, 0, 0, 45), Size = UDim2.new(0, 150, 1, -45), BackgroundColor3 = currentTheme.CardBackground, Parent = self.MainFrame
    })
    CreateElement("Frame", {Position = UDim2.new(1, -1, 0, 0), Size = UDim2.new(0, 1, 1, 0), BackgroundColor3 = currentTheme.Border, BorderSizePixel = 0, Parent = self.Sidebar})
    
    CreateElement("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 5), Parent = self.Sidebar})
    CreateElement("UIPadding", {PaddingTop = UDim.new(0, 12), PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), Parent = self.Sidebar})

    -- Elements Center Board Holder
    self.ContainerHolder = CreateElement("Frame", {
        Position = UDim2.new(0, 150, 0, 45), Size = UDim2.new(1, -150, 1, -45), BackgroundTransparency = 1, Parent = self.MainFrame
    })

    return self
end

function KitsuneLib:CreateTab(name)
    local currentTheme = self.Theme
    local tabSelf = {}
    
    -- ULTRA-VISIBLE TAB BUTTON (FIXED TEXT COLOR & POSITION)
    local tabButton = CreateElement("TextButton", {
        Text = name, Font = Enum.Font.GothamBold, TextSize = 12, 
        TextColor3 = currentTheme.TextSecondary, -- Memastikan teks berwarna kontras tinggi
        Size = UDim2.new(1, 0, 0, 34), 
        BackgroundColor3 = Color3.fromRGB(30, 30, 36), -- Ditambahkan warna base box agar kontras dari background
        BackgroundTransparency = 0.4, AutoButtonColor = false, 
        TextXAlignment = Enum.TextXAlignment.Center, Parent = self.Sidebar
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 6), Parent = tabButton})
    local btnStroke = CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = tabButton})

    -- Left Border Accent Bar
    local accentStrip = CreateElement("Frame", {
        Size = UDim2.new(0, 3, 0, 14), Position = UDim2.new(0, 4, 0.5, -7), BackgroundColor3 = currentTheme.AccentPrimary, BackgroundTransparency = 1, Parent = tabButton
    })
    CreateElement("UICorner", {CornerRadius = UDim.new(0, 1), Parent = accentStrip})

    -- Scrolling Frame Body
    local tabScroll = CreateElement("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Visible = false, ScrollBarThickness = 3, ScrollBarImageColor3 = currentTheme.AccentPrimary, CanvasSize = UDim2.new(0,0,0,0), Parent = self.ContainerHolder
    })
    local elementLayout = CreateElement("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8), Parent = tabScroll})
    CreateElement("UIPadding", {PaddingTop = UDim.new(0, 16), PaddingLeft = UDim.new(0, 16), PaddingRight = UDim.new(0, 16), Parent = tabScroll})
    
    elementLayout.Changed:Connect(function()
        tabScroll.CanvasSize = UDim2.new(0, 0, 0, elementLayout.AbsoluteContentSize.Y + 32)
    end)

    local function Activate()
        if self.ActiveTab then
            TweenService:Create(self.ActiveTab.Button, TweenInfo.new(0.2), {BackgroundTransparency = 0.4, TextColor3 = currentTheme.TextSecondary}):Play()
            TweenService:Create(self.ActiveTab.Stroke, TweenInfo.new(0.2), {Color = currentTheme.Border}):Play()
            TweenService:Create(self.ActiveTab.Strip, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            self.ActiveTab.Scroll.Visible = false
        end
        TweenService:Create(tabButton, TweenInfo.new(0.2), {BackgroundTransparency = 0, TextColor3 = currentTheme.TextPrimary}):Play()
        TweenService:Create(btnStroke, TweenInfo.new(0.2), {Color = currentTheme.AccentPrimary}):Play()
        TweenService:Create(accentStrip, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
        tabScroll.Visible = true
        self.ActiveTab = {Button = tabButton, Stroke = btnStroke, Strip = accentStrip, Scroll = tabScroll}
    end

    tabButton.MouseButton1Click:Connect(Activate)
    
    local actualButtons = 0
    for _, child in pairs(self.Sidebar:GetChildren()) do
        if child:IsA("TextButton") then actualButtons = actualButtons + 1 end
    end
    if actualButtons == 1 then Activate() end

    -- 1. PREMIUM UTILITY BUTTON
    function tabSelf:CreateButton(text, callback)
        local btn = CreateElement("TextButton", {
            Text = text, Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = currentTheme.TextPrimary,
            Size = UDim2.new(1, 0, 0, 40), BackgroundColor3 = currentTheme.CardBackground, AutoButtonColor = false, Parent = tabScroll
        })
        CreateElement("UICorner", {CornerRadius = UDim.new(0, 6), Parent = btn})
        local stroke = CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = btn})
        
        btn.MouseEnter:Connect(function() TweenService:Create(stroke, TweenInfo.new(0.18), {Color = currentTheme.AccentPrimary}):Play() end)
        btn.MouseLeave:Connect(function() TweenService:Create(stroke, TweenInfo.new(0.18), {Color = currentTheme.Border}):Play() end)
        btn.MouseButton1Click:Connect(function() pcall(callback) end)
    end

    -- 2. PREMIUM UTILITY TOGGLE
    function tabSelf:CreateToggle(text, default, callback)
        local enabled = default or false
        local card = CreateElement("Frame", {Size = UDim2.new(1, 0, 0, 44), BackgroundColor3 = currentTheme.CardBackground, Parent = tabScroll})
        CreateElement("UICorner", {CornerRadius = UDim.new(0, 6), Parent = card})
        local stroke = CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = card})

        CreateElement("TextLabel", {
            Text = text, Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = currentTheme.TextPrimary,
            Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(0.7, 0, 1, 0), TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Parent = card
        })

        local switch = CreateElement("TextButton", {
            Text = "", Size = UDim2.new(0, 36, 0, 20), Position = UDim2.new(1, -50, 0.5, -10),
            BackgroundColor3 = enabled and currentTheme.AccentPrimary or currentTheme.Background, AutoButtonColor = false, Parent = card
        })
        CreateElement("UICorner", {CornerRadius = UDim.new(1, 0), Parent = switch})
        
        local circle = CreateElement("Frame", {
            Size = UDim2.new(0, 14, 0, 14), Position = enabled and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7),
            BackgroundColor3 = currentTheme.TextPrimary, Parent = switch
        })
        CreateElement("UICorner", {CornerRadius = UDim.new(1, 0), Parent = circle})

        switch.MouseButton1Click:Connect(function()
            enabled = not enabled
            TweenService:Create(switch, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {BackgroundColor3 = enabled and currentTheme.AccentPrimary or currentTheme.Background}):Play()
            TweenService:Create(circle, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {Position = enabled and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)}):Play()
            pcall(callback, enabled)
        end)
    end

    -- 3. PREMIUM UTILITY SLIDER
    function tabSelf:CreateSlider(text, min, max, default, callback)
        local value = default or min
        local card = CreateElement("Frame", {Size = UDim2.new(1, 0, 0, 52), BackgroundColor3 = currentTheme.CardBackground, Parent = tabScroll})
        CreateElement("UICorner", {CornerRadius = UDim.new(0, 6), Parent = card})
        local stroke = CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = card})
        
        local title = CreateElement("TextLabel", {
            Text = text, Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = currentTheme.TextPrimary,
            Position = UDim2.new(0, 14, 0, 8), Size = UDim2.new(0.6, 0, 0, 16), TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Parent = card
        })
        local valueLabel = CreateElement("TextLabel", {
            Text = tostring(value), Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = currentTheme.AccentPrimary,
            Position = UDim2.new(1, -64, 0, 8), Size = UDim2.new(0, 50, 0, 16), TextXAlignment = Enum.TextXAlignment.Right, BackgroundTransparency = 1, Parent = card
        })

        local slideTrack = CreateElement("TextButton", {
            Text = "", Size = UDim2.new(1, -28, 0, 5), Position = UDim2.new(0, 14, 1, -14),
            BackgroundColor3 = currentTheme.Background, AutoButtonColor = false, Parent = card
        })
        CreateElement("UICorner", {CornerRadius = UDim.new(1, 0), Parent = slideTrack})

        local slideFill = CreateElement("Frame", {
            Size = UDim2.new((value - min)/(max - min), 0, 1, 0), BackgroundColor3 = currentTheme.AccentPrimary, Parent = slideTrack
        })
        CreateElement("UICorner", {CornerRadius = UDim.new(1, 0), Parent = slideFill})

        local function updateSlider(input)
            local scale = math.clamp((input.Position.X - slideTrack.AbsolutePosition.X) / slideTrack.AbsoluteSize.X, 0, 1)
            value = math.floor(min + (max - min) * scale)
            valueLabel.Text = tostring(value)
            slideFill.Size = UDim2.new(scale, 0, 1, 0)
            pcall(callback, value)
        end

        local sliding = false
        slideTrack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = true updateSlider(input) end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then updateSlider(input) end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliding = false end
        end)
    end

    -- 4. PREMIUM UTILITY DROPDOWN
    function tabSelf:CreateDropdown(text, list, callback)
        local expanded = false
        local card = CreateElement("Frame", {Size = UDim2.new(1, 0, 0, 42), BackgroundColor3 = currentTheme.CardBackground, ClipsDescendants = true, Parent = tabScroll})
        CreateElement("UICorner", {CornerRadius = UDim.new(0, 6), Parent = card})
        local stroke = CreateElement("UIStroke", {Thickness = 1, Color = currentTheme.Border, Parent = card})

        local btn = CreateElement("TextButton", {
            Text = text .. "    ▼", Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = currentTheme.TextPrimary,
            Size = UDim2.new(1, 0, 0, 42), BackgroundTransparency = 1, AutoButtonColor = false, TextXAlignment = Enum.TextXAlignment.Left, Parent = card
        })
        CreateElement("UIPadding", {PaddingLeft = UDim.new(0, 14), Parent = btn})

        local itemHolder = CreateElement("Frame", {Position = UDim2.new(0, 0, 0, 42), Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1, Visible = false, Parent = card})
        local itemLayout = CreateElement("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Parent = itemHolder})

        for _, option in pairs(list) do
            local item = CreateElement("TextButton", {
                Text = option, Font = Enum.Font.Gotham, TextSize = 11.5, TextColor3 = currentTheme.TextSecondary,
                Size = UDim2.new(1, 0, 0, 30), BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left, Parent = itemHolder
            })
            CreateElement("UIPadding", {PaddingLeft = UDim.new(0, 14), Parent = item})
            
            item.MouseButton1Click:Connect(function()
                btn.Text = text .. " : " .. option .. "    ▼"
                expanded = false
                itemHolder.Visible = false
                TweenService:Create(card, TweenInfo.new(0.2, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, 42)}):Play()
                pcall(callback, option)
            end)
        end

        btn.MouseButton1Click:Connect(function()
            expanded = not expanded
            if expanded then
                itemHolder.Visible = true
                TweenService:Create(card, TweenInfo.new(0.18, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, 42 + itemLayout.AbsoluteContentSize.Y)}):Play()
            else
                itemHolder.Visible = false
                TweenService:Create(card, TweenInfo.new(0.18, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, 42)}):Play()
            end
        end)
    end

    return tabSelf
end

return KitsuneLib
