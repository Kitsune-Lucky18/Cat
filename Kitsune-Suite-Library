        valueLabel.Font = Enum.Font.GothamBold
        valueLabel.TextSize = 12
        valueLabel.TextColor3 = currentTheme.AccentPrimary
        valueLabel.Position = UDim2.new(1, -64, 0, 8)
        valueLabel.Size = UDim2.new(0, 50, 0, 16)
        valueLabel.TextXAlignment = Enum.TextXAlignment.Right
        valueLabel.BackgroundTransparency = 1
        valueLabel.Parent = card

        local slideTrack = Instance.new("TextButton")
        slideTrack.Text = ""
        slideTrack.Size = UDim2.new(1, -28, 0, 5)
        slideTrack.Position = UDim2.new(0, 14, 1, -14)
        slideTrack.BackgroundColor3 = currentTheme.Background
        slideTrack.AutoButtonColor = false
