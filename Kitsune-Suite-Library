    local tabButton = Instance.new("TextButton") tabButton.Text = "" tabButton.Size = UDim2.new(1, 0, 0, 34) tabButton.BackgroundColor3 = currentTheme.Background tabButton.BackgroundTransparency = 0.3 tabButton.AutoButtonColor = false tabButton.Parent = self.TabScrollCanvas
    local tBtnCorner = Instance.new("UICorner") tBtnCorner.CornerRadius = UDim.new(0, 6) tBtnCorner.Parent = tabButton
    local btnStroke = Instance.new("UIStroke") btnStroke.Thickness = 1 btnStroke.Color = currentTheme.Border btnStroke.Parent = tabButton
    local accentStrip = Instance.new("Frame") accentStrip.Size = UDim2.new(0, 3, 0, 14) accentStrip.Position = UDim2.new(0, 4, 0.5, -7) accentStrip.BackgroundColor3 = currentTheme.AccentPrimary accentStrip.BackgroundTransparency = 1 accentStrip.Parent = tabButton
    local stripCorner = Instance.new("UICorner") stripCorner.CornerRadius = UDim.new(0, 1) stripCorner.Parent = accentStrip

    local tabIcon = nil
    if icon and icon ~= "" then
        tabIcon = Instance.new("ImageLabel") tabIcon.Size = UDim2.new(0, 16, 0, 16) tabIcon.Position = UDim2.new(0, 12, 0.5, -8) tabIcon.BackgroundTransparency = 1 tabIcon.Image = icon tabIcon.ImageColor3 = currentTheme.TextSecondary tabIcon.Parent = tabButton
    end

    local tabLabel = Instance.new("TextLabel") tabLabel.Text = name tabLabel.Font = Enum.Font.GothamBold tabLabel.TextSize = 12 tabLabel.TextColor3 = currentTheme.TextSecondary tabLabel.BackgroundTransparency = 1
    if tabIcon then tabLabel.Position = UDim2.new(0, 34, 0, 0) tabLabel.Size = UDim2.new(1, -38, 1, 0) tabLabel.TextXAlignment = Enum.TextXAlignment.Left else tabLabel.Position = UDim2.new(0, 0, 0, 0) tabLabel.Size = UDim2.new(1, 0, 1, 0) tabLabel.TextXAlignment = Enum.TextXAlignment.Center end
    tabLabel.Parent = tabButton

    local tabScroll = Instance.new("ScrollingFrame") tabScroll.Size = UDim2.new(1, 0, 1, 0) tabScroll.BackgroundTransparency = 1 tabScroll.Visible = false tabScroll.ScrollBarThickness = 3 tabScroll.ScrollBarImageColor3 = currentTheme.AccentPrimary tabScroll.CanvasSize = UDim2.new(0, 0, 0, 0) tabScroll.Parent = self.ContainerHolder
    local elementLayout = Instance.new("UIListLayout") elementLayout.SortOrder = Enum.SortOrder.LayoutOrder elementLayout.Padding = UDim.new(0, 8) elementLayout.Parent = tabScroll
    local elementPadding = Instance.new("UIPadding") elementPadding.PaddingTop = UDim.new(0, 16) elementPadding.PaddingLeft = UDim.new(0, 16) elementPadding.PaddingRight = UDim.new(0, 16) elementPadding.Parent = tabScroll
    
    elementLayout.Changed:Connect(function() tabScroll.CanvasSize = UDim2.new(0, 0, 0, elementLayout.AbsoluteContentSize.Y + 32) end)

    local function Activate()
        if self.ActiveTab then
            TweenService:Create(self.ActiveTab.Button, TweenInfo.new(0.15), {BackgroundTransparency = 0.3}):Play()
            TweenService:Create(self.ActiveTab.Label, TweenInfo.new(0.15), {TextColor3 = currentTheme.TextSecondary}):Play()
            if self.ActiveTab.Icon then TweenService:Create(self.ActiveTab.Icon, TweenInfo.new(0.15), {ImageColor3 = currentTheme.TextSecondary}):Play() end
            TweenService:Create(self.ActiveTab.Stroke, TweenInfo.new(0.15), {Color = currentTheme.Border}):Play()
            TweenService:Create(self.ActiveTab.Strip, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
            self.ActiveTab.Scroll.Visible = false
        end
        TweenService:Create(tabButton, TweenInfo.new(0.15), {BackgroundTransparency = 0}):Play()
        TweenService:Create(tabLabel, TweenInfo.new(0.15), {TextColor3 = currentTheme.TextPrimary}):Play()
        if tabIcon then TweenService:Create(tabIcon, TweenInfo.new(0.15), {ImageColor3 = currentTheme.TextPrimary}):Play() end
        TweenService:Create(btnStroke, TweenInfo.new(0.15), {Color = currentTheme.AccentPrimary}):Play()
        TweenService:Create(accentStrip, TweenInfo.new(0.15), {BackgroundTransparency = 0}):Play()
        tabScroll.Visible = true
        self.ActiveTab = {Button = tabButton, Label = tabLabel, Icon = tabIcon, Stroke = btnStroke, Strip = accentStrip, Scroll = tabScroll}
    end

    tabButton.MouseButton1Click:Connect(Activate)
    if self.FirstTab then self.FirstTab = false Activate() end

    -- ==========================================
    -- CORE ELEMENTS IMPLEMENTATION
    -- ==========================================

    function tabSelf:CreateButton(text, icon, callback)
        local btn = Instance.new("TextButton") btn.Text = "" btn.Size = UDim2.new(1, 0, 0, 40) btn.BackgroundColor3 = currentTheme.CardBackground btn.AutoButtonColor = false btn.Parent = tabScroll
        local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, 6) c.Parent = btn
        local stroke = Instance.new("UIStroke") stroke.Thickness = 1 stroke.Color = currentTheme.Border stroke.Parent = btn
        
        local bLabel = Instance.new("TextLabel") bLabel.Text = text bLabel.Font = Enum.Font.GothamBold bLabel.TextSize = 12 bLabel.TextColor3 = currentTheme.TextPrimary bLabel.BackgroundTransparency = 1 bLabel.Parent = btn
        if icon and icon ~= "" then
            local bIcon = Instance.new("ImageLabel") bIcon.Size = UDim2.new(0, 16, 0, 16) bIcon.Position = UDim2.new(0, 14, 0.5, -8) bIcon.BackgroundTransparency = 1 bIcon.Image = icon bIcon.ImageColor3 = currentTheme.TextPrimary bIcon.Parent = btn
            bLabel.Position = UDim2.new(0, 38, 0, 0) bLabel.Size = UDim2.new(1, -44, 1, 0) bLabel.TextXAlignment = Enum.TextXAlignment.Left
        else
            bLabel.Size = UDim2.new(1, 0, 1, 0) bLabel.TextXAlignment = Enum.TextXAlignment.Center
        end

        btn.MouseEnter:Connect(function() TweenService:Create(stroke, TweenInfo.new(0.15), {Color = currentTheme.AccentPrimary}):Play() end)
        btn.MouseLeave:Connect(function() TweenService:Create(stroke, TweenInfo.new(0.15), {Color = currentTheme.Border}):Play() end)
        btn.MouseButton1Click:Connect(function() pcall(callback) end)
    end

    function tabSelf:CreateToggle(text, default, callback)
        local enabled = default or false
        local card = Instance.new("Frame") card.Size = UDim2.new(1, 0, 0, 44) card.BackgroundColor3 = currentTheme.CardBackground card.Parent = tabScroll
        local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, 6) c.Parent = card
