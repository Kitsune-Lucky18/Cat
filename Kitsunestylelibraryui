		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 46),
		Parent = self.Page,
	}, { corner(9), stroke() })

	create("TextLabel", {
		Text = config.Name or "Progress",
		Font = FONT,
		TextSize = 12.5,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(14, 6),
		Size = UDim2.new(1, -28, 0, 16),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local Track = create("Frame", {
		Size = UDim2.new(1, -28, 0, 6),
		Position = UDim2.fromOffset(14, 30),
		BackgroundColor3 = Theme.Stroke,
		Parent = Holder,
	}, { corner(3) })

	local Fill = create("Frame", {
		Size = UDim2.new(math.clamp(value / max, 0, 1), 0, 1, 0),
		BackgroundColor3 = Theme.Accent,
		Parent = Track,
	}, { corner(3) })

	return {
		Set = function(v)
			value = math.clamp(v, 0, max)
			tween(Fill, { Size = UDim2.new(value / max, 0, 1, 0) }, 0.25)
		end,
	}
end

-- ============ ELEMENT: PROGRESS RING ============
-- Ring melingkar untuk menampilkan persentase progres secara visual
-- (cocok untuk loading circular, level indicator, dll).
--
-- local xpRing = Tab:CreateProgressRing({ Name = "Level 5 XP", CurrentValue = 60, Max = 100 })
-- xpRing.Set(80)
function UILibrary.CreateProgressRing(self, config)
	config = config or {}
	local value = config.CurrentValue or 0
	local max = config.Max or 100

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 80),
		Parent = self.Page,
	}, { corner(9), stroke() })

	local RingWrap = create("Frame", {
		Size = UDim2.fromOffset(54, 54),
		Position = UDim2.fromOffset(13, 13),
		BackgroundColor3 = Theme.Section,
		Parent = Holder,
	}, { corner(27), stroke(Theme.Accent, 4) })

	local PercentLabel = create("TextLabel", {
		Text = math.floor(math.clamp(value / max, 0, 1) * 100) .. "%",
		Font = FONT_BOLD,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.fromScale(1, 1),
		Parent = RingWrap,
	})

	create("TextLabel", {
		Text = config.Name or "",
		Font = FONT,
		TextSize = 12.5,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(80, 28),
		Size = UDim2.new(1, -94, 0, 20),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	return {
		Set = function(v)
			value = math.clamp(v, 0, max)
			PercentLabel.Text = math.floor((value / max) * 100) .. "%"
		end,
	}
end

-- ============ THEME FUNCTIONS ============
-- UILibrary:GetThemes() -> daftar 20 nama tema yang tersedia, dalam urutan tetap.
function UILibrary:GetThemes()
	local list = {}
	for _, name in ipairs(ThemeOrder) do table.insert(list, name) end
	return list
end

-- UILibrary:GetActiveTheme() -> nama tema yang sedang aktif (string)
function UILibrary:GetActiveTheme()
	return ActiveThemeName
end

-- UILibrary:SetTheme(name)
-- Mengganti tema aktif. Paling efektif dipanggil SEBELUM CreateWindow,
-- karena warna sudah "dibakar" ke setiap komponen saat dibuat — komponen
-- yang dibuat SEBELUM SetTheme dipanggil tidak otomatis berubah warna.
-- Kalau perlu ganti tema di tengah jalan (live), cara paling aman adalah
-- memanggil SetTheme lalu membuat ulang window dari awal.
function UILibrary:SetTheme(name)
	local preset = Themes[name]
	if not preset then
		warn("[UILibrary] Tema '" .. tostring(name) .. "' tidak ditemukan. Gunakan UILibrary:GetThemes() untuk lihat daftar nama yang valid.")
		return false
	end
	for k, v in pairs(preset) do
		Theme[k] = v
	end
	ActiveThemeName = name
	for _, listener in ipairs(ThemeChangedListeners) do
		pcall(listener, name)
	end
	return true
end

-- UILibrary:OnThemeChanged(callback)
-- Daftarkan fungsi yang dipanggil setiap kali SetTheme dipakai, kalau kamu
-- mau bikin logic custom (misalnya re-render sesuatu) saat tema berganti.
function UILibrary:OnThemeChanged(callback)
	table.insert(ThemeChangedListeners, callback)
end

-- ============ THEME PICKER (dropdown di dalam UI) ============
-- Komponen siap pakai untuk ditaruh di tab "Appearance"/"Settings".
-- Memanggil UILibrary:SetTheme() saat opsi dipilih. Karena warna komponen
-- lain sudah dibuat sebelumnya, paling rapi dipakai bersama rekomendasi:
-- minta pemain reopen menu / panggil ulang CreateWindow setelah ganti tema.
--
-- CONTOH:
-- Tab:CreateThemePicker({
--     Name = "UI Theme",
--     OnChange = function(themeName)
--         print("Tema diganti ke:", themeName)
--         -- contoh: tampilkan notif minta reload window
--     end
-- })
function UILibrary.CreateThemePicker(self, config)
	config = config or {}
	local name = config.Name or "UI Theme"
	local onChange = config.OnChange or function() end

	return self:CreateDropdown({
		Name = name,
		Options = ThemeOrder,
		CurrentOption = ActiveThemeName,
		Callback = function(selected)
			UILibrary:SetTheme(selected)
			UILibrary:Notify({
				Title = "Tema diganti",
				Content = "Tema \"" .. selected .. "\" aktif. Buka ulang menu untuk melihat perubahan penuh.",
				Type = "Info",
			})
			local ok, err = pcall(onChange, selected)
			if not ok then warn("[UILibrary] ThemePicker OnChange error:", err) end
		end
	})
end

return UILibrary
