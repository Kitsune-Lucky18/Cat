function UILibrary.CreateButton(self, config)
	config = config or {}
	local name = config.Name or "Button"
	local callback = config.Callback or function() end

	local Holder = create("TextButton", {
		Text = "",
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 38),
		AutoButtonColor = false,
		Parent = self.Page,
	}, { corner(8), stroke() })

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -24, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	Holder.MouseEnter:Connect(function() tween(Holder, {BackgroundColor3 = Theme.ElementHover}, 0.15) end)
	Holder.MouseLeave:Connect(function() tween(Holder, {BackgroundColor3 = Theme.Element}, 0.15) end)
	Holder.MouseButton1Click:Connect(function()
		tween(Holder, {BackgroundColor3 = Theme.Accent}, 0.1)
		task.delay(0.1, function() tween(Holder, {BackgroundColor3 = Theme.ElementHover}, 0.15) end)
		local ok, err = pcall(callback)
		if not ok then warn("[UILibrary] Button callback error:", err) end
	end)

	return Holder
end

-- ============ ELEMENT: TOGGLE ============
function UILibrary.CreateToggle(self, config)
	config = config or {}
	local name = config.Name or "Toggle"
	local state = config.CurrentValue or false
	local callback = config.Callback or function() end

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 38),
		Parent = self.Page,
	}, { corner(8), stroke() })

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -60, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local Switch = create("Frame", {
		Size = UDim2.fromOffset(38, 20),
		Position = UDim2.new(1, -50, 0.5, -10),
		BackgroundColor3 = state and Theme.Accent or Theme.Stroke,
		Parent = Holder,
	}, { corner(10) })

	local Knob = create("Frame", {
		Size = UDim2.fromOffset(16, 16),
		Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent = Switch,
	}, { corner(8) })

	local ClickArea = create("TextButton", {
		Text = "",
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = Holder,
	})

	local function setState(newState, fire)
		state = newState
		tween(Switch, {BackgroundColor3 = state and Theme.Accent or Theme.Stroke}, 0.15)
		tween(Knob, {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)}, 0.15)
		if fire then
			local ok, err = pcall(callback, state)
			if not ok then warn("[UILibrary] Toggle callback error:", err) end
		end
	end

	ClickArea.MouseButton1Click:Connect(function() setState(not state, true) end)

	return { Set = function(v) setState(v, true) end }
end

-- ============ ELEMENT: SLIDER ============
function UILibrary.CreateSlider(self, config)
	config = config or {}
	local name = config.Name or "Slider"
	local range = config.Range or {0, 100}
	local increment = config.Increment or 1
	local value = config.CurrentValue or range[1]
	local callback = config.Callback or function() end

	local min, max = range[1], range[2]

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 50),
		Parent = self.Page,
	}, { corner(8), stroke() })

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -70, 0, 24),
		Position = UDim2.fromOffset(12, 4),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local ValueLabel = create("TextLabel", {
		Text = tostring(value),
		Font = FONT,
		TextSize = 12,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(50, 24),
		Position = UDim2.new(1, -62, 0, 4),
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = Holder,
	})

	local Track = create("Frame", {
		Size = UDim2.new(1, -24, 0, 6),
		Position = UDim2.fromOffset(12, 34),
		BackgroundColor3 = Theme.Stroke,
		Parent = Holder,
	}, { corner(3) })

	local function pct(v) return (v - min) / (max - min) end

	local Fill = create("Frame", {
		Size = UDim2.new(pct(value), 0, 1, 0),
		BackgroundColor3 = Theme.Accent,
		Parent = Track,
	}, { corner(3) })

	local Knob = create("Frame", {
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(pct(value), -7, 0.5, -7),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent = Track,
	}, { corner(7) })

	local dragging = false

	local function updateFromX(xPos)
		local relative = math.clamp((xPos - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
		local raw = min + relative * (max - min)
		local stepped = math.clamp(math.floor(raw / increment + 0.5) * increment, min, max)
		if stepped ~= value then
			value = stepped
			ValueLabel.Text = tostring(value)
			Fill.Size = UDim2.new(pct(value), 0, 1, 0)
			Knob.Position = UDim2.new(pct(value), -7, 0.5, -7)
			local ok, err = pcall(callback, value)
			if not ok then warn("[UILibrary] Slider callback error:", err) end
		end
	end

	Track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromX(input.Position.X)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromX(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	return { Set = function(v) updateFromX(Track.AbsolutePosition.X + pct(v) * Track.AbsoluteSize.X) end }
end

