		Main = Main,
		Sidebar = TabScroll,
		Body = Body,
		Tabs = {},
		_firstTab = true,
		_visible = true,
		_minimized = false,
	}
	setmetatable(Window, UILibrary)

	local function setVisible(v)
		Window._visible = v
		if v then
			ScreenGui.Enabled = true
			Main.Size = UDim2.fromOffset(size.X.Offset, 0)
			tween(Main, {Size = size}, 0.2)
		else
			tween(Main, {Size = UDim2.fromOffset(size.X.Offset, 0)}, 0.2)
			task.delay(0.2, function() ScreenGui.Enabled = false end)
		end
	end

	local RestoreSquare = create("Frame", {
		Size = UDim2.fromOffset(9, 9),
		Position = UDim2.new(0.5, -4.5, 0.5, -4.5),
		BackgroundColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Parent = MinimizeBtn,
	}, { corner(2), stroke(Theme.SubText, 1.5) })
	RestoreSquare.Visible = false

	local function setMinimized(v)
		Window._minimized = v
		Sidebar.Visible = not v
		Body.Visible = not v
		MinimizeLine.Visible = not v
		RestoreSquare.Visible = v
		if v then
			tween(Main, {Size = UDim2.fromOffset(size.X.Offset, 46)}, 0.2)
		else
			tween(Main, {Size = size}, 0.2)
		end
	end

	MinimizeBtn.MouseButton1Click:Connect(function() setMinimized(not Window._minimized) end)
	CloseBtn.MouseButton1Click:Connect(function() setVisible(false) end)

	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.KeyCode == toggleKey then
			setVisible(not Window._visible)
		end
	end)

	Window.SetVisible = function(_, v) setVisible(v) end
	Window.SetMinimized = function(_, v) setMinimized(v) end

	return Window
end

