function UILibrary.CreateTab(self, name, icon)
	local Sidebar = self.Sidebar
	local Body = self.Body

	local TabButton = create("TextButton", {
		Text = "",
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.SubText,
		BackgroundColor3 = Theme.Element,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 32),
		AutoButtonColor = false,
		Parent = Sidebar,
	}, { corner(6) })

	local iconInst = makeIcon(icon, 15, Theme.SubText)
	local labelOffsetX = 12
	if iconInst then
		iconInst.Position = UDim2.fromOffset(10, 8.5)
		iconInst.Parent = TabButton
		labelOffsetX = 32
	end

	local TabLabel = create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -labelOffsetX - 6, 1, 0),
		Position = UDim2.fromOffset(labelOffsetX, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = TabButton,
	})

	local Page = create("ScrollingFrame", {
		Name = name .. "Page",
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = Theme.Accent,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false,
		Parent = Body,
	})

	create("UIPadding", {
		PaddingTop = UDim.new(0, 12),
		PaddingLeft = UDim.new(0, 12),
		PaddingRight = UDim.new(0, 12),
		PaddingBottom = UDim.new(0, 12),
	}).Parent = Page

	create("UIListLayout", {
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = Page

	local Tab = { Page = Page, Button = TabButton, Label = TabLabel, Icon = iconInst, Window = self }
	setmetatable(Tab, UILibrary)

	local function selectTab()
		for _, t in pairs(self.Tabs) do
			t.Page.Visible = false
			tween(t.Button, {BackgroundTransparency = 1}, 0.15)
			tween(t.Label, {TextColor3 = Theme.SubText}, 0.15)
			if t.Icon then tween(t.Icon, {ImageColor3 = Theme.SubText}, 0.15) end
		end
		Page.Visible = true
		tween(TabButton, {BackgroundTransparency = 0}, 0.15)
		tween(TabLabel, {TextColor3 = Theme.Text}, 0.15)
		if iconInst then tween(iconInst, {ImageColor3 = Theme.Text}, 0.15) end
	end

	TabButton.MouseButton1Click:Connect(selectTab)
	TabButton.MouseEnter:Connect(function()
		if not Page.Visible then tween(TabButton, {BackgroundTransparency = 0.7}, 0.15) end
	end)
	TabButton.MouseLeave:Connect(function()
		if not Page.Visible then tween(TabButton, {BackgroundTransparency = 1}, 0.15) end
	end)

	table.insert(self.Tabs, Tab)

	if self._firstTab then
		self._firstTab = false
		selectTab()
	end

	return Tab
end

