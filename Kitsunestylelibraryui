function UILibrary.CreateDropdown(self, config)
	config = config or {}
	local name = config.Name or "Dropdown"
	local options = config.Options or {}
	local current = config.CurrentOption or options[1] or ""
	local callback = config.Callback or function() end

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 38),
		ClipsDescendants = true,
		ZIndex = 2,
		Parent = self.Page,
	}, { corner(8), stroke() })

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.5, -12, 0, 38),
		Position = UDim2.fromOffset(12, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local SelectedBtn = create("TextButton", {
		Text = current .. "  ▾",
		Font = FONT,
		TextSize = 12,
		TextColor3 = Theme.SubText,
		BackgroundColor3 = Theme.ElementHover,
		Size = UDim2.new(0.5, -12, 0, 26),
		Position = UDim2.new(0.5, 0, 0, 6),
		AutoButtonColor = false,
		Parent = Holder,
	}, { corner(6) })

	local ListFrame = create("Frame", {
		BackgroundColor3 = Theme.ElementHover,
		Size = UDim2.new(0.5, -12, 0, #options * 26),
		Position = UDim2.new(0.5, 0, 0, 38),
		ZIndex = 3,
		Parent = Holder,
	}, { corner(6) })

	create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = ListFrame

	local open = false

	local function setOpen(state)
		open = state
		Holder.Size = state and UDim2.new(1, 0, 0, 38 + #options * 26 + 6) or UDim2.new(1, 0, 0, 38)
	end

	for _, opt in ipairs(options) do
		local OptBtn = create("TextButton", {
			Text = opt,
			Font = FONT,
			TextSize = 12,
			TextColor3 = Theme.Text,
			BackgroundColor3 = Theme.ElementHover,
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 26),
			ZIndex = 3,
			Parent = ListFrame,
		})
		OptBtn.MouseEnter:Connect(function() tween(OptBtn, {BackgroundTransparency = 0}, 0.1) end)
		OptBtn.MouseLeave:Connect(function() tween(OptBtn, {BackgroundTransparency = 1}, 0.1) end)
		OptBtn.MouseButton1Click:Connect(function()
			current = opt
			SelectedBtn.Text = current .. "  ▾"
			setOpen(false)
			local ok, err = pcall(callback, current)
			if not ok then warn("[UILibrary] Dropdown callback error:", err) end
		end)
	end

	SelectedBtn.MouseButton1Click:Connect(function() setOpen(not open) end)

	return { Set = function(opt) current = opt; SelectedBtn.Text = opt .. "  ▾" end }
end

