	local offsetX = 12
	if iconInst then
		iconInst.Position = UDim2.fromOffset(12, 11)
		iconInst.Parent = Holder
		offsetX = 32
	end

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -offsetX - 60, 0, 38),
		Position = UDim2.fromOffset(offsetX, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local Swatch = create("TextButton", {
		Text = "",
		BackgroundColor3 = current,
		Size = UDim2.fromOffset(28, 22),
		Position = UDim2.new(1, -40, 0, 8),
		AutoButtonColor = false,
		Parent = Holder,
	}, { corner(6), stroke() })

	-- Mini RGB sliders panel (revealed on click)
	local Panel = create("Frame", {
		BackgroundColor3 = Theme.ElementHover,
		Size = UDim2.new(1, -24, 0, 90),
		Position = UDim2.fromOffset(12, 44),
		Parent = Holder,
	}, { corner(6) })

	create("UIListLayout", {
		Padding = UDim.new(0, 6),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = Panel
	create("UIPadding", {
		PaddingTop = UDim.new(0, 8), PaddingLeft = UDim.new(0, 8), PaddingRight = UDim.new(0, 8),
	}).Parent = Panel

	local open = false
	local function setOpen(state)
		open = state
		Holder.Size = state and UDim2.new(1, 0, 0, 144) or UDim2.new(1, 0, 0, 38)
	end

	local r, g, b = current.R * 255, current.G * 255, current.B * 255

	local function makeChannel(label, initial, onChange)
		local Row = create("Frame", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20), Parent = Panel })
		create("TextLabel", {
			Text = label, Font = FONT, TextSize = 11, TextColor3 = Theme.SubText,
			BackgroundTransparency = 1, Size = UDim2.fromOffset(16, 20), Parent = Row,
		})
		local Track = create("Frame", {
			BackgroundColor3 = Theme.Stroke,
			Size = UDim2.new(1, -50, 0, 4), Position = UDim2.fromOffset(24, 8),
			Parent = Row,
		}, { corner(2) })
		local Fill = create("Frame", {
			BackgroundColor3 = Theme.Accent,
			Size = UDim2.new(initial / 255, 0, 1, 0),
			Parent = Track,
		}, { corner(2) })
		local dragging = false
		local function update(xPos)
			local relative = math.clamp((xPos - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
			Fill.Size = UDim2.new(relative, 0, 1, 0)
			onChange(relative * 255)
		end
		Track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				update(input.Position.X)
			end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				update(input.Position.X)
			end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
		end)
	end

	local function refreshSwatch()
		local color = Color3.fromRGB(r, g, b)
		Swatch.BackgroundColor3 = color
		local ok, err = pcall(callback, color)
		if not ok then warn("[UILibrary] ColorPicker callback error:", err) end
	end

	makeChannel("R", r, function(v) r = v; refreshSwatch() end)
	makeChannel("G", g, function(v) g = v; refreshSwatch() end)
	makeChannel("B", b, function(v) b = v; refreshSwatch() end)

	Swatch.MouseButton1Click:Connect(function() setOpen(not open) end)

	return { Set = function(color) r, g, b = color.R*255, color.G*255, color.B*255; refreshSwatch() end }
end

