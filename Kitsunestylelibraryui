local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local UILibrary = {}
UILibrary.__index = UILibrary

-- ============ THEME ============
local Theme = {
	Background     = Color3.fromRGB(24, 24, 27),
	Sidebar        = Color3.fromRGB(20, 20, 22),
	Section        = Color3.fromRGB(30, 30, 34),
	Element        = Color3.fromRGB(38, 38, 43),
	ElementHover   = Color3.fromRGB(46, 46, 52),
	Accent         = Color3.fromRGB(105, 92, 255),
	AccentHover    = Color3.fromRGB(125, 112, 255),
	Text           = Color3.fromRGB(235, 235, 240),
	SubText        = Color3.fromRGB(150, 150, 160),
	Stroke         = Color3.fromRGB(50, 50, 56),
	Success        = Color3.fromRGB(80, 200, 120),
	Error          = Color3.fromRGB(235, 90, 90),
	Warning        = Color3.fromRGB(235, 180, 70),
	Info           = Color3.fromRGB(95, 150, 235),
}

local FONT = Enum.Font.GothamMedium
local FONT_BOLD = Enum.Font.GothamBold

-- ============ HELPERS ============
local function create(class, props, children)
	local inst = Instance.new(class)
	for prop, value in pairs(props or {}) do
		inst[prop] = value
	end
	for _, child in ipairs(children or {}) do
		child.Parent = inst
	end
	return inst
end

local function corner(radius)
	return create("UICorner", { CornerRadius = UDim.new(0, radius or 8) })
end

local function stroke(color, thickness)
	return create("UIStroke", {
		Color = color or Theme.Stroke,
		Thickness = thickness or 1,
	})
end

local function tween(obj, props, duration, style)
	TweenService:Create(obj, TweenInfo.new(duration or 0.18, style or Enum.EasingStyle.Quad), props):Play()
end

local function makeDraggable(frame, dragHandle)
	local dragging = false
	local dragStart, startPos

	dragHandle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	dragHandle.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

-- ============ NOTIFICATION HOLDER (global, lives outside window) ============
local NotifyHolder

local function ensureNotifyHolder()
	if NotifyHolder and NotifyHolder.Parent then return NotifyHolder end

	local Gui = create("ScreenGui", {
		Name = "CustomUILibrary_Notify",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = PlayerGui,
	})

	NotifyHolder = create("Frame", {
		Name = "NotifyHolder",
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(300, 500),
		Position = UDim2.new(1, -316, 1, -16),
		AnchorPoint = Vector2.new(0, 1),
		Parent = Gui,
	})

	create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		VerticalAlignment = Enum.VerticalAlignment.Bottom,
		Padding = UDim.new(0, 8),
	}).Parent = NotifyHolder

	return NotifyHolder
end

-- ============ NOTIFY ============
-- UILibrary:Notify({ Title, Content, Duration, Type })
function UILibrary:Notify(config)
	config = config or {}
	local title = config.Title or "Notification"
	local content = config.Content or ""
	local duration = config.Duration or 4
	local notifType = config.Type or "Info" -- Success | Error | Warning | Info

	local colorMap = {
		Success = Theme.Success,
		Error = Theme.Error,
		Warning = Theme.Warning,
		Info = Theme.Info,
	}
	local iconMap = {
		Success = "✓",
		Error = "✕",
		Warning = "!",
		Info = "i",
	}
	local barColor = colorMap[notifType] or Theme.Accent

	local Holder = ensureNotifyHolder()

	local Card = create("Frame", {
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundColor3 = Theme.Section,
		ClipsDescendants = true,
		LayoutOrder = -os.clock(),
		Parent = Holder,
	}, { corner(10), stroke() })

	create("Frame", {
		Name = "AccentBar",
		Size = UDim2.new(0, 4, 1, 0),
		BackgroundColor3 = barColor,
		Parent = Card,
	}, { corner(2) })

	local IconCircle = create("Frame", {
		Size = UDim2.fromOffset(26, 26),
		Position = UDim2.fromOffset(14, 12),
		BackgroundColor3 = barColor,
		BackgroundTransparency = 0.85,
		Parent = Card,
	}, { corner(13) })

	create("TextLabel", {
		Text = iconMap[notifType] or "i",
		Font = FONT_BOLD,
		TextSize = 13,
		TextColor3 = barColor,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = IconCircle,
	})

	create("TextLabel", {
		Text = title,
		Font = FONT_BOLD,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(50, 10),
		Size = UDim2.new(1, -64, 0, 18),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Card,
	})

	create("TextLabel", {
		Text = content,
		Font = FONT,
		TextSize = 12,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(50, 28),
		Size = UDim2.new(1, -64, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Card,
	})

	create("UIPadding", { PaddingBottom = UDim.new(0, 12) }).Parent = Card

	-- Slide-in animation
	Card.Position = UDim2.new(1, 40, 0, 0)
	Card.Size = UDim2.new(1, 0, 0, 0)
	tween(Card, { Position = UDim2.new(0, 0, 0, 0) }, 0.25, Enum.EasingStyle.Quint)

	task.delay(duration, function()
		tween(Card, { Position = UDim2.new(1, 40, 0, 0) }, 0.25, Enum.EasingStyle.Quint)
		task.delay(0.25, function()
			Card:Destroy()
		end)
	end)
end

-- ============ WINDOW ============
function UILibrary:CreateWindow(config)
	config = config or {}
	local title = config.Title or "UI Library"
	local subtitle = config.SubTitle or ""
	local size = config.Size or UDim2.fromOffset(620, 420)
	local toggleKey = config.ToggleKey or Enum.KeyCode.RightShift

	local existing = PlayerGui:FindFirstChild("CustomUILibrary")
	if existing then existing:Destroy() end

	local ScreenGui = create("ScreenGui", {
		Name = "CustomUILibrary",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent = PlayerGui,
	})

	local Main = create("Frame", {
		Name = "Main",
		Size = size,
		Position = UDim2.new(0.5, -size.X.Offset/2, 0.5, -size.Y.Offset/2),
		BackgroundColor3 = Theme.Background,
		ClipsDescendants = true,
		Parent = ScreenGui,
	}, { corner(12), stroke(Theme.Stroke, 1) })

	-- Top bar (draggable)
	local TopBar = create("Frame", {
		Name = "TopBar",
		Size = UDim2.new(1, 0, 0, 46),
		BackgroundColor3 = Theme.Sidebar,
		Parent = Main,
	}, { corner(12) })

	create("Frame", {
		Size = UDim2.new(1, 0, 0, 12),
		Position = UDim2.new(0, 0, 1, -12),
		BackgroundColor3 = Theme.Sidebar,
		BorderSizePixel = 0,
		Parent = TopBar,
	})

	create("TextLabel", {
		Text = title,
		Font = FONT_BOLD,
		TextSize = 15,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(16, 4),
		Size = UDim2.new(1, -80, 0, 18),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = TopBar,
	})

	if subtitle ~= "" then
		create("TextLabel", {
			Text = subtitle,
			Font = FONT,
			TextSize = 11,
			TextColor3 = Theme.SubText,
			BackgroundTransparency = 1,
			Position = UDim2.fromOffset(16, 23),
			Size = UDim2.new(1, -80, 0, 16),
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = TopBar,
		})
	end

	local CloseBtn = create("TextButton", {
		Text = "✕",
		Font = FONT_BOLD,
		TextSize = 14,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(38, 38),
		Position = UDim2.new(1, -42, 0, 4),
		Parent = TopBar,
	})
	CloseBtn.MouseEnter:Connect(function() tween(CloseBtn, {TextColor3 = Theme.Text}, 0.15) end)
	CloseBtn.MouseLeave:Connect(function() tween(CloseBtn, {TextColor3 = Theme.SubText}, 0.15) end)

	makeDraggable(Main, TopBar)

	-- Sidebar (tab list)
	local Sidebar = create("Frame", {
		Name = "Sidebar",
		Size = UDim2.new(0, 150, 1, -46),
		Position = UDim2.fromOffset(0, 46),
		BackgroundColor3 = Theme.Sidebar,
		Parent = Main,
	})

	local TabScroll = create("ScrollingFrame", {
		Size = UDim2.new(1, 0, 1, -8),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 2,
		ScrollBarImageColor3 = Theme.Accent,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Parent = Sidebar,
	})

	create("UIListLayout", {
		Padding = UDim.new(0, 4),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = TabScroll

	create("UIPadding", {
		PaddingTop = UDim.new(0, 10),
		PaddingLeft = UDim.new(0, 8),
		PaddingRight = UDim.new(0, 8),
	}).Parent = TabScroll

	-- Body (tab content container)
	local Body = create("Frame", {
		Name = "Body",
		Size = UDim2.new(1, -150, 1, -46),
		Position = UDim2.fromOffset(150, 46),
		BackgroundColor3 = Theme.Background,
		Parent = Main,
	})

	local Window = {
		ScreenGui = ScreenGui,
		Main = Main,
		Sidebar = TabScroll,
		Body = Body,
		Tabs = {},
		_firstTab = true,
		_visible = true,
	}
	setmetatable(Window, UILibrary)

	local function setVisible(v)
		Window._visible = v
		if v then
			ScreenGui.Enabled = true
			Main.Size = UDim2.fromOffset(size.X.Offset, 0)
			tween(Main, {Size = size}, 0.2)
		else
			tween(Main, {Size = UDim2.fromOffset(size.X.Offset, 0)}, 0.2)
			task.delay(0.2, function() ScreenGui.Enabled = false end)
		end
	end

	CloseBtn.MouseButton1Click:Connect(function() setVisible(false) end)

	UserInputService.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.KeyCode == toggleKey then
			setVisible(not Window._visible)
		end
	end)

	Window.SetVisible = function(_, v) setVisible(v) end

	return Window
end

-- ============ TAB ============
function UILibrary.CreateTab(self, name)
	local Sidebar = self.Sidebar
	local Body = self.Body

	local TabButton = create("TextButton", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.SubText,
		BackgroundColor3 = Theme.Element,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 32),
		AutoButtonColor = false,
		Parent = Sidebar,
	}, { corner(6) })

	local Page = create("ScrollingFrame", {
		Name = name .. "Page",
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = Theme.Accent,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false,
		Parent = Body,
	})

	create("UIPadding", {
		PaddingTop = UDim.new(0, 12),
		PaddingLeft = UDim.new(0, 12),
		PaddingRight = UDim.new(0, 12),
		PaddingBottom = UDim.new(0, 12),
	}).Parent = Page

	create("UIListLayout", {
		Padding = UDim.new(0, 8),
		SortOrder = Enum.SortOrder.LayoutOrder,
	}).Parent = Page

	local Tab = { Page = Page, Button = TabButton, Window = self }
	setmetatable(Tab, UILibrary)

	local function selectTab()
		for _, t in pairs(self.Tabs) do
			t.Page.Visible = false
			tween(t.Button, {BackgroundTransparency = 1, TextColor3 = Theme.SubText}, 0.15)
		end
		Page.Visible = true
		tween(TabButton, {BackgroundTransparency = 0, TextColor3 = Theme.Text}, 0.15)
	end

	TabButton.MouseButton1Click:Connect(selectTab)
	TabButton.MouseEnter:Connect(function()
		if not Page.Visible then tween(TabButton, {BackgroundTransparency = 0.7}, 0.15) end
	end)
	TabButton.MouseLeave:Connect(function()
		if not Page.Visible then tween(TabButton, {BackgroundTransparency = 1}, 0.15) end
	end)

	table.insert(self.Tabs, Tab)

	if self._firstTab then
		self._firstTab = false
		selectTab()
	end

	return Tab
end

