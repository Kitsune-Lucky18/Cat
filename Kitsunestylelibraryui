-- ============ HELPERS ============
local function create(class, props, children)
	local inst = Instance.new(class)
	for prop, value in pairs(props or {}) do
		inst[prop] = value
	end
	for _, child in ipairs(children or {}) do
		child.Parent = inst
	end
	return inst
end

local function corner(radius)
	return create("UICorner", { CornerRadius = UDim.new(0, radius or 8) })
end

local function stroke(color, thickness)
	return create("UIStroke", {
		Color = color or Theme.Stroke,
		Thickness = thickness or 1,
	})
end

local function tween(obj, props, duration, style)
	TweenService:Create(obj, TweenInfo.new(duration or 0.18, style or Enum.EasingStyle.Quad), props):Play()
end

-- makeIcon(icon, size, color)
-- Menerima "rbxassetid://..." atau angka ID gambar. Dipakai untuk
-- menampilkan icon di samping label komponen (misalnya hasil upload
-- icon Lucide kamu sendiri ke Roblox). Return nil kalau icon tidak diisi,
-- jadi layout otomatis menyesuaikan (geser label ke kiri).
local function makeIcon(icon, size, color)
	if not icon or icon == "" then return nil end
	local assetId = icon
	if type(icon) == "number" then
		assetId = "rbxassetid://" .. tostring(icon)
	elseif type(icon) == "string" and not icon:match("^rbxasset") then
		assetId = "rbxassetid://" .. icon
	end
	return create("ImageLabel", {
		Image = assetId,
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(size or 16, size or 16),
		ImageColor3 = color or Theme.Text,
	})
end

local function makeDraggable(frame, dragHandle)
	local dragging = false
	local dragStart, startPos

	dragHandle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	dragHandle.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)
end

