	create("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		VerticalAlignment = Enum.VerticalAlignment.Bottom,
		Padding = UDim.new(0, 8),
	}).Parent = NotifyHolder

	return NotifyHolder
end

-- ============ NOTIFY ============
-- UILibrary:Notify({ Title, Content, Duration, Type })
function UILibrary:Notify(config)
	config = config or {}
	local title = config.Title or "Notification"
	local content = config.Content or ""
	local duration = config.Duration or 4
	local notifType = config.Type or "Info" -- Success | Error | Warning | Info

	local colorMap = {
		Success = Theme.Success,
		Error = Theme.Error,
		Warning = Theme.Warning,
		Info = Theme.Info,
	}
	local iconMap = {
		Success = "✓",
		Error = "✕",
		Warning = "!",
		Info = "i",
	}
	local barColor = colorMap[notifType] or Theme.Accent

	local Holder = ensureNotifyHolder()

	local Card = create("Frame", {
		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		BackgroundColor3 = Theme.Section,
		ClipsDescendants = true,
		LayoutOrder = -os.clock(),
		Parent = Holder,
	}, { corner(10), stroke() })

	create("Frame", {
		Name = "AccentBar",
		Size = UDim2.new(0, 4, 1, 0),
		BackgroundColor3 = barColor,
		Parent = Card,
	}, { corner(2) })

	local IconCircle = create("Frame", {
		Size = UDim2.fromOffset(26, 26),
		Position = UDim2.fromOffset(14, 12),
		BackgroundColor3 = barColor,
		BackgroundTransparency = 0.85,
		Parent = Card,
	}, { corner(13) })

	create("TextLabel", {
		Text = iconMap[notifType] or "i",
		Font = FONT_BOLD,
		TextSize = 13,
		TextColor3 = barColor,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = IconCircle,
	})

	create("TextLabel", {
		Text = title,
		Font = FONT_BOLD,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(50, 10),
		Size = UDim2.new(1, -64, 0, 18),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Card,
	})

	create("TextLabel", {
		Text = content,
		Font = FONT,
		TextSize = 12,
		TextColor3 = Theme.SubText,
