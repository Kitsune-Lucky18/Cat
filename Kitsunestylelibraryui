	Holder.MouseButton1Click:Connect(function()
		-- OpenBrowserWindowAsync hanya berjalan di platform yang mendukungnya
		-- (PC/mobile app Roblox). Dibungkus pcall supaya tidak error di platform lain.
		local ok, err = pcall(function()
