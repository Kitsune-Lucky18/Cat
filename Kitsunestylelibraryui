	NotifyHolder = create("Frame", {
		Name = "NotifyHolder",
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(300, 500),
		Position = UDim2.new(1, -316, 1, -16),
		AnchorPoint = Vector2.new(0, 1),
