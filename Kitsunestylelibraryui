-- ============ ELEMENT: SLIDER ============
function UILibrary.CreateSlider(self, config)
	config = config or {}
	local name = config.Name or "Slider"
	local icon = config.Icon
	local range = config.Range or {0, 100}
	local increment = config.Increment or 1
	local value = config.CurrentValue or range[1]
	local callback = config.Callback or function() end

	local min, max = range[1], range[2]

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 50),
		Parent = self.Page,
	}, { corner(8), stroke() })

	local iconInst = makeIcon(icon, 15, Theme.Text)
	local offsetX = 12
	if iconInst then
		iconInst.Position = UDim2.fromOffset(12, 5)
		iconInst.Parent = Holder
		offsetX = 32
	end

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -offsetX - 70, 0, 24),
		Position = UDim2.fromOffset(offsetX, 4),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local ValueLabel = create("TextLabel", {
		Text = tostring(value),
		Font = FONT,
		TextSize = 12,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(50, 24),
		Position = UDim2.new(1, -62, 0, 4),
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = Holder,
	})

	local Track = create("Frame", {
		Size = UDim2.new(1, -24, 0, 6),
		Position = UDim2.fromOffset(12, 34),
		BackgroundColor3 = Theme.Stroke,
		Parent = Holder,
	}, { corner(3) })

	local function pct(v) return (v - min) / (max - min) end

	local Fill = create("Frame", {
		Size = UDim2.new(pct(value), 0, 1, 0),
		BackgroundColor3 = Theme.Accent,
		Parent = Track,
	}, { corner(3) })

	local Knob = create("Frame", {
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(pct(value), -7, 0.5, -7),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		Parent = Track,
	}, { corner(7) })

	local dragging = false

	local function updateFromX(xPos)
		local relative = math.clamp((xPos - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
		local raw = min + relative * (max - min)
		local stepped = math.clamp(math.floor(raw / increment + 0.5) * increment, min, max)
		if stepped ~= value then
			value = stepped
			ValueLabel.Text = tostring(value)
			Fill.Size = UDim2.new(pct(value), 0, 1, 0)
			Knob.Position = UDim2.new(pct(value), -7, 0.5, -7)
			local ok, err = pcall(callback, value)
			if not ok then warn("[UILibrary] Slider callback error:", err) end
		end
	end

	Track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			updateFromX(input.Position.X)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromX(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	return { Set = function(v) updateFromX(Track.AbsolutePosition.X + pct(v) * Track.AbsoluteSize.X) end }
end

-- ============ ELEMENT: DROPDOWN ============
function UILibrary.CreateDropdown(self, config)
	config = config or {}
	local name = config.Name or "Dropdown"
	local icon = config.Icon
	local options = config.Options or {}
	local multiSelect = config.MultiSelect or false
	local current = config.CurrentOption or options[1] or ""
	local selected = {}
	if multiSelect then
		for _, v in ipairs(config.CurrentOptions or {}) do selected[v] = true end
	end
	local callback = config.Callback or function() end

	local function selectedCount()
		local count = 0
		for _ in pairs(selected) do count += 1 end
		return count
	end

	local function selectedList()
		local list = {}
		for opt in pairs(selected) do table.insert(list, opt) end
		return list
	end

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 38),
		ClipsDescendants = true,
		ZIndex = 2,
		Parent = self.Page,
	}, { corner(8), stroke() })

	local iconInst = makeIcon(icon, 15, Theme.Text)
	local offsetX = 12
	if iconInst then
		iconInst.Position = UDim2.fromOffset(12, 11)
		iconInst.Parent = Holder
		offsetX = 32
	end

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(0.5, -offsetX, 0, 38),
		Position = UDim2.fromOffset(offsetX, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local SelectedBtn = create("TextButton", {
		Text = multiSelect and (selectedCount() .. " dipilih") or current,
		Font = FONT,
		TextSize = 12,
		TextColor3 = Theme.SubText,
		BackgroundColor3 = Theme.ElementHover,
		Size = UDim2.new(0.5, -12, 0, 26),
		Position = UDim2.new(0.5, 0, 0, 6),
		AutoButtonColor = false,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	}, { corner(6) })
	create("UIPadding", { PaddingLeft = UDim.new(0, 10) }).Parent = SelectedBtn

	-- Chevron-down dibentuk dari 2 garis kecil (V), bukan karakter Unicode,
	-- supaya tampil konsisten di semua platform/font.
	local ChevronWrap = create("Frame", {
		Size = UDim2.fromOffset(10, 6),
		Position = UDim2.new(1, -18, 0.5, -3),
		BackgroundTransparency = 1,
		Parent = SelectedBtn,
	})
	create("Frame", {
		Size = UDim2.fromOffset(6, 2),
		Position = UDim2.fromOffset(0, 1),
		Rotation = 45,
		BackgroundColor3 = Theme.SubText,
		BorderSizePixel = 0,
		Parent = ChevronWrap,
	}, { corner(1) })
	create("Frame", {
		Size = UDim2.fromOffset(6, 2),
		Position = UDim2.fromOffset(4, 1),
		Rotation = -45,
		BackgroundColor3 = Theme.SubText,
		BorderSizePixel = 0,
		Parent = ChevronWrap,
	}, { corner(1) })

	local ListFrame = create("Frame", {
		BackgroundColor3 = Theme.ElementHover,
		Size = UDim2.new(0.5, -12, 0, #options * 26),
		Position = UDim2.new(0.5, 0, 0, 38),
		ZIndex = 3,
		Parent = Holder,
	}, { corner(6) })

	create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = ListFrame

	local open = false

	local function setOpen(state)
		open = state
		Holder.Size = state and UDim2.new(1, 0, 0, 38 + #options * 26 + 6) or UDim2.new(1, 0, 0, 38)
	end

	local optionButtons = {}

	for _, opt in ipairs(options) do
		local OptBtn = create("TextButton", {
			Text = opt,
			Font = FONT,
			TextSize = 12,
			TextColor3 = Theme.Text,
			BackgroundColor3 = multiSelect and Theme.Accent or Theme.ElementHover,
			BackgroundTransparency = (multiSelect and selected[opt]) and 0.5 or 1,
			Size = UDim2.new(1, 0, 0, 26),
			ZIndex = 3,
			Parent = ListFrame,
		})
		optionButtons[opt] = OptBtn

		OptBtn.MouseEnter:Connect(function()
			if not (multiSelect and selected[opt]) then tween(OptBtn, {BackgroundTransparency = 0.8}, 0.1) end
		end)
		OptBtn.MouseLeave:Connect(function()
			if not (multiSelect and selected[opt]) then tween(OptBtn, {BackgroundTransparency = 1}, 0.1) end
		end)

		OptBtn.MouseButton1Click:Connect(function()
			if multiSelect then
				selected[opt] = not selected[opt] or nil
				tween(OptBtn, { BackgroundTransparency = selected[opt] and 0.5 or 1 }, 0.1)
				SelectedBtn.Text = selectedCount() .. " dipilih"
				local ok, err = pcall(callback, selectedList())
				if not ok then warn("[UILibrary] Dropdown callback error:", err) end
			else
				current = opt
				SelectedBtn.Text = current
				setOpen(false)
				local ok, err = pcall(callback, current)
				if not ok then warn("[UILibrary] Dropdown callback error:", err) end
			end
		end)
	end

	SelectedBtn.MouseButton1Click:Connect(function() setOpen(not open) end)

	if multiSelect then
		return {
			Set = function(list)
				selected = {}
				for _, v in ipairs(list) do selected[v] = true end
				for opt, btn in pairs(optionButtons) do
					btn.BackgroundTransparency = selected[opt] and 0.5 or 1
				end
				SelectedBtn.Text = selectedCount() .. " dipilih"
			end,
			Get = function() return selectedList() end,
		}
	end

	return { Set = function(opt) current = opt; SelectedBtn.Text = opt end, Get = function() return current end }
end

