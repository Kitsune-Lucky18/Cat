function UILibrary.CreateKeybind(self, config)
	config = config or {}
	local name = config.Name or "Keybind"
	local current = config.CurrentKeybind or "None"
	local callback = config.Callback or function() end

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 38),
		Parent = self.Page,
	}, { corner(8), stroke() })

	create("TextLabel", {
		Text = name,
		Font = FONT,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -100, 1, 0),
		Position = UDim2.fromOffset(12, 0),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local BindBtn = create("TextButton", {
		Text = current,
		Font = FONT,
		TextSize = 12,
		TextColor3 = Theme.Text,
		BackgroundColor3 = Theme.ElementHover,
		Size = UDim2.fromOffset(80, 26),
		Position = UDim2.new(1, -92, 0.5, -13),
		AutoButtonColor = false,
		Parent = Holder,
	}, { corner(6) })

	local listening = false

	BindBtn.MouseButton1Click:Connect(function()
		listening = true
		BindBtn.Text = "..."
	end)

	UserInputService.InputBegan:Connect(function(input, gpe)
		if not listening then return end
		if input.UserInputType == Enum.UserInputType.Keyboard then
			current = input.KeyCode.Name
			BindBtn.Text = current
			listening = false
			local ok, err = pcall(callback, current)
			if not ok then warn("[UILibrary] Keybind callback error:", err) end
		end
	end)

	return { Set = function(key) current = key; BindBtn.Text = key end }
end

return UILibrary
