-- ============ GAMEPASS TIER (Bronze / Silver / Gold) ============
-- Sistem premium berbasis GamePass resmi Roblox — TIDAK ada loadstring
-- tersembunyi, semua kode sudah ada di game sejak awal. Pemain membeli
-- gamepass lewat MarketplaceService, dan kamu mendapat Robux dari Roblox
-- (dipotong fee marketplace) seperti transaksi gamepass biasa.
--
-- CONTOH PEMAKAIAN:
--
-- local tierIds = {
--     Bronze = 0000001, -- ganti dengan GamePass ID kamu
--     Silver = 0000002,
--     Gold   = 0000003,
-- }
--
-- Tab:CreateGamepassTier({
--     Name = "Bronze Pass",
--     Tier = "Bronze",                 -- "Bronze" | "Silver" | "Gold"
--     GamepassId = tierIds.Bronze,
--     Price = 99,                      -- opsional, hanya untuk tampilan label harga
--     OnUnlocked = function()
--         print("Pemain sudah punya Bronze Pass — tampilkan fitur di sini")
--     end,
-- })

local TIER_COLORS = {
	Bronze = Color3.fromRGB(196, 132, 84),
	Silver = Color3.fromRGB(190, 195, 205),
	Gold   = Color3.fromRGB(230, 188, 90),
}

function UILibrary.CreateGamepassTier(self, config)
	config = config or {}
	local name = config.Name or "Premium Pass"
	local icon = config.Icon
	local tier = config.Tier or "Bronze"
	local gamepassId = config.GamepassId
	local price = config.Price
	local onUnlocked = config.OnUnlocked or function() end
	local onError = config.OnError or function() end

	local tierColor = TIER_COLORS[tier] or Theme.Accent

	local Holder = create("Frame", {
		BackgroundColor3 = Theme.Element,
		Size = UDim2.new(1, 0, 0, 54),
		Parent = self.Page,
	}, { corner(8), stroke() })

	create("Frame", {
		Size = UDim2.fromOffset(4, 38),
		Position = UDim2.fromOffset(0, 8),
		BackgroundColor3 = tierColor,
		Parent = Holder,
	}, { corner(2) })

	local iconInst = makeIcon(icon, 15, Theme.Text)
	local labelOffsetX = 18
	if iconInst then
		iconInst.Position = UDim2.fromOffset(18, 9)
		iconInst.Parent = Holder
		labelOffsetX = 38
	end

	create("TextLabel", {
		Text = name,
		Font = FONT_BOLD,
		TextSize = 13,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(labelOffsetX, 8),
		Size = UDim2.new(1, -labelOffsetX - 122, 0, 18),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local statusText = price and ("Belum dimiliki  •  " .. tostring(price) .. " R$") or "Memuat status..."
	local StatusLabel = create("TextLabel", {
		Text = statusText,
		Font = FONT,
		TextSize = 11,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(labelOffsetX, 27),
		Size = UDim2.new(1, -labelOffsetX - 122, 0, 16),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Holder,
	})

	local ActionBtn = create("TextButton", {
		Text = "Cek status...",
		Font = FONT_BOLD,
		TextSize = 12,
		TextColor3 = Color3.fromRGB(255,255,255),
		BackgroundColor3 = tierColor,
		Size = UDim2.fromOffset(100, 32),
		Position = UDim2.new(1, -112, 0.5, -16),
		AutoButtonColor = false,
		Parent = Holder,
	}, { corner(7) })

	local owned = false

	local function refreshUI()
		if owned then
			StatusLabel.Text = "Aktif"
			StatusLabel.TextColor3 = Theme.Success
			ActionBtn.Text = "Dimiliki ✓"
			ActionBtn.BackgroundColor3 = Theme.ElementHover
			ActionBtn.AutoButtonColor = false
		else
			StatusLabel.Text = price and ("Belum dimiliki  •  " .. tostring(price) .. " R$") or "Belum dimiliki"
			StatusLabel.TextColor3 = Theme.SubText
			ActionBtn.Text = "Beli"
			ActionBtn.BackgroundColor3 = tierColor
		end
	end

	local function checkOwnership()
		if not gamepassId then
			StatusLabel.Text = "GamepassId belum diisi"
			StatusLabel.TextColor3 = Theme.Warning
			ActionBtn.Text = "—"
			return
		end
		local ok, result = pcall(function()
			return MarketplaceService:UserOwnsGamePassAsync(LocalPlayer.UserId, gamepassId)
		end)
		if ok then
			owned = result
			refreshUI()
			if owned then
				local cbOk, cbErr = pcall(onUnlocked)
				if not cbOk then warn("[UILibrary] OnUnlocked callback error:", cbErr) end
			end
		else
			StatusLabel.Text = "Gagal memeriksa status"
			StatusLabel.TextColor3 = Theme.Error
			local cbOk, cbErr = pcall(onError, result)
			if not cbOk then warn("[UILibrary] OnError callback error:", cbErr) end
		end
	end

	ActionBtn.MouseButton1Click:Connect(function()
		if owned then return end
		if not gamepassId then return end
		MarketplaceService:PromptGamePassPurchase(LocalPlayer, gamepassId)
	end)

	-- Roblox akan memicu event ini setelah pembelian selesai diproses
	MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, purchasedId, wasPurchased)
		if player == LocalPlayer and purchasedId == gamepassId and wasPurchased then
			owned = true
			refreshUI()
			local cbOk, cbErr = pcall(onUnlocked)
			if not cbOk then warn("[UILibrary] OnUnlocked callback error:", cbErr) end
			UILibrary:Notify({
				Title = name .. " Diaktifkan!",
				Content = "Terima kasih sudah membeli " .. tier .. " Pass.",
				Type = "Success",
			})
		end
	end)

	task.spawn(checkOwnership)

	return {
		Refresh = checkOwnership,
		IsOwned = function() return owned end,
	}
end

